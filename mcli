def print_mcli_usage():
    print("Helios Diagnostics CLI (mcli) - Mimir Host & Cluster Diagnostic Engine\n")
    print("Usage:")
    print("  mcli [--verbose|-v] health_checks run_all       Run all diagnostic checks cluster-wide")
    print("  mcli [--verbose|-v] health_checks services      Run only service-related checks")
    print("  mcli [--verbose|-v] health_checks hardware      Run only hardware-related checks")
    print("  mcli [--verbose|-v] health_checks storage       Run only storage-related checks")
    print("  mcli health_checks list                         List all available diagnostic checks")
    print("  mcli [--verbose|-v] status                      Show the latest diagnostic results from ScyllaDB")
    print("\nExamples:")
    print("  mcli -v health_checks run_all    # Execute checks showing passed results")
    print("  mcli -v status                   # View status report including outputs")

def main():
    global VERBOSE
    # Handle global verbose argument anywhere
    if "--verbose" in sys.argv:
        VERBOSE = True
        sys.argv.remove("--verbose")
    if "-v" in sys.argv:
        VERBOSE = True
        sys.argv.remove("-v")
        
    if len(sys.argv) < 2 or sys.argv[1] in ["--help", "-h", "help"]:
        print_mcli_usage()
        sys.exit(1)
        
    cmd = sys.argv[1]
    if cmd == "status":
        show_status()
    elif cmd == "health_checks":
        if len(sys.argv) < 3:
            print("Usage: mcli health_checks <run_all|services|hardware|storage|list>")
            sys.exit(1)
        sub = sys.argv[2]
        if sub == "list":
            show_list()
        elif sub in ["run_all", "services", "hardware", "storage"]:
            category = "all" if sub == "run_all" else sub
            execute_health_checks(category)
        else:
            print(f"Unknown sub-command '{sub}'")
            sys.exit(1)
    else:
        print(f"Unknown command '{cmd}'")
        sys.exit(1)

if __name__ == "__main__":
    main()
