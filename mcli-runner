#!/usr/bin/env python3
import sys
import subprocess
import json
import os
import re
import time

def run_cmd(cmd):
    res = subprocess.run(cmd, shell=True, stdout=subprocess.PIPE, stderr=subprocess.PIPE)
    return res.returncode, res.stdout.decode('utf-8', errors='ignore').strip(), res.stderr.decode('utf-8', errors='ignore').strip()

def is_zookeeper_leader():
    try:
        import socket
        s = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
        s.settimeout(0.5)
        s.connect(("127.0.0.1", 2181))
        s.sendall(b"stat")
        resp = s.recv(1024).decode('utf-8', errors='ignore')
        s.close()
        return "mode: leader" in resp.lower() or "mode: standalone" in resp.lower()
    except Exception:
        return False

def get_drbd_role(resource_name):
    rc, out, err = run_cmd(f"podman exec systemd-aether drbdadm role {resource_name}")
    if rc == 0:
        return out.strip()
    return "Secondary"

def update_current_check(category, check_name):
    try:
        with open(f"/tmp/mimir_check_{category}", "w") as f:
            f.write(check_name)
    except Exception:
        pass

def is_urbosa_enabled():
    try:
        import socket
        local_ip = "127.0.0.1"
        try:
            s = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
            s.connect(("8.8.8.8", 80))
            local_ip = s.getsockname()[0]
            s.close()
        except Exception:
            pass
        cql = "SELECT value FROM hydra.cluster_settings WHERE key = 'urbosa_enabled';"
        res = subprocess.run(f"podman exec -i systemd-hydra-db cqlsh {local_ip} -e \"{cql}\"", shell=True, stdout=subprocess.PIPE, stderr=subprocess.PIPE)
        out = res.stdout.decode('utf-8', errors='ignore')
        return "true" in out.lower()
    except Exception:
        return False

def check_services(category):
    results = {}
    
    # 1. Systemd service statuses
    urbosa_active = is_urbosa_enabled()
    in_maint = os.path.exists("/etc/hci/maintenance.state")
    svcs = ["zookeeper", "hydra-db", "daruk", "aether", "spark-daemon", "spectrum", "catalyst", "bifrost", "dagur", "mimir", "vali", "gatoway", "logos", "mipha", "agahnim", "slate", "hylia", "libvirtd"]
    if urbosa_active:
        svcs.append("urbosa")
        
    for svc in svcs:
        update_current_check(category, f"{svc}_status")
        rc, out, err = run_cmd(f"systemctl is-active {svc}")
        is_active = (out == "active")
        
        # Handle virtualization services with socket activation fallback
        if svc == "libvirtd":
            # Check if any of libvirtd/virtqemud service/sockets are active
            rc_sock1, out_sock1, _ = run_cmd("systemctl is-active libvirtd.socket")
            rc_fallback, out_fallback, _ = run_cmd("systemctl is-active virtqemud")
            rc_sock2, out_sock2, _ = run_cmd("systemctl is-active virtqemud.socket")
            if is_active or out_sock1 == "active" or out_fallback == "active" or out_sock2 == "active":
                is_active = True
                out = "active (virtualization active/socket-activated)"
                err = ""

        if in_maint:
            # In maintenance mode, core consensus/storage should be active. Workloads can be active or inactive, we pass them.
            if svc in ["zookeeper", "hydra-db", "daruk", "aether", "spark-daemon"]:
                status = "PASS" if is_active else "FAIL"
            else:
                status = "PASS"
        else:
            status = "PASS" if is_active else "FAIL"
            
        results[f"{svc}_status"] = {
            "status": status,
            "output": f"Service is {out}.\nSystemd Output:\n{out or err}"
        }
        
    if not urbosa_active:
        results["urbosa_status"] = {
            "status": "PASS",
            "output": "[SKIPPED] Urbosa service status check bypassed because Urbosa SDN is currently deactivated in cluster settings."
        }
        
    # 2. ScyllaDB Ring status (using nodetool)
    update_current_check(category, "scylladb_ring_status")
    rc, out, err = run_cmd("podman exec systemd-hydra-db nodetool status")
    if rc == 0:
        # Check if any nodes are Down or Joining
        dn_count = len(re.findall(r"^DN\s", out, re.MULTILINE))
        uj_count = len(re.findall(r"^UJ\s", out, re.MULTILINE))
        if dn_count > 0:
            status = "FAIL"
            msg = f"Detected {dn_count} DOWN node(s) in ScyllaDB ring!\n{out}"
        elif uj_count > 0:
            status = "WARN"
            msg = f"Detected {uj_count} joining node(s) in ScyllaDB ring.\n{out}"
        else:
            status = "PASS"
            msg = f"All ScyllaDB ring nodes are UP and Normal (UN).\n{out}"
    else:
        status = "FAIL"
        msg = f"Failed to execute nodetool status: {err or out}"
        
    results["scylladb_ring_status"] = {
        "status": status,
        "output": msg
    }
    
    # 3. ZooKeeper Consensus mode check
    update_current_check(category, "zookeeper_consensus")
    try:
        import socket
        s = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
        s.settimeout(1.0)
        s.connect(("127.0.0.1", 2181))
        s.sendall(b"stat")
        resp = s.recv(1024).decode('utf-8', errors='ignore')
        s.close()
        mode = "unknown"
        for line in resp.splitlines():
            if "mode:" in line.lower():
                mode = line.split(":")[-1].strip()
        if mode in ["leader", "follower"]:
            status = "PASS"
            msg = f"ZooKeeper is online and participating in consensus. Mode: {mode}."
        else:
            status = "WARN"
            msg = f"ZooKeeper is online but consensus mode is unexpected: {mode}.\nFull stat response:\n{resp}"
    except Exception as e:
        status = "FAIL"
        msg = f"Failed to connect to ZooKeeper on 127.0.0.1:2181: {str(e)}"
    results["zookeeper_consensus"] = {
        "status": status,
        "output": msg
    }
    
    # 4. ScyllaDB Keyspace Replication Check
    update_current_check(category, "scylladb_replication")
    try:
        import socket
        local_ip = "127.0.0.1"
        try:
            s = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
            s.connect(("8.8.8.8", 80))
            local_ip = s.getsockname()[0]
            s.close()
        except Exception:
            pass
        cql = "SELECT replication FROM system_schema.keyspaces WHERE keyspace_name = 'hydra';"
        rc, out, err = run_cmd("podman exec -i systemd-hydra-db cqlsh " + local_ip + " -e \"" + cql + "\"")
        if rc == 0 and "replication_factor" in out:
            if "'replication_factor': '3'" in out or "replication_factor': '3'" in out or "'3'" in out:
                status = "PASS"
                msg = f"Keyspace 'hydra' is configured with replication factor 3.\n{out}"
            else:
                status = "WARN"
                msg = f"Keyspace 'hydra' replication configuration is unexpected:\n{out}"
        else:
            status = "FAIL"
            msg = f"Failed to query keyspace replication: {err or out}"
    except Exception as e:
        status = "FAIL"
        msg = f"Failed to run ScyllaDB replication check: {str(e)}"
    results["scylladb_replication"] = {
        "status": status,
        "output": msg
    }
    
    # 5. Spectrum port reachability
    update_current_check(category, "spectrum_api_port")
    in_maint = os.path.exists("/etc/hci/maintenance.state")
    if in_maint:
        status = "PASS"
        msg = "[SKIPPED] Host is in maintenance mode; Spectrum API port 8443 is not expected to be open."
    else:
        try:
            import socket
            s = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
            s.settimeout(1.0)
            s.connect(("127.0.0.1", 8443))
            s.close()
            status = "PASS"
            msg = "Spectrum API Web Console port 8443 is open and accepting TCP connections."
        except Exception as e:
            status = "FAIL"
            msg = f"Failed to connect to Spectrum API on port 8443: {str(e)}"
    results["spectrum_api_port"] = {
        "status": status,
        "output": msg
    }
    
    # 6. mTLS Client Certificate Expiration Check
    update_current_check(category, "mtls_cert_expiration")
    cert_path = "/root/.certs/client.crt"
    if os.path.exists(cert_path):
        rc, out, err = run_cmd(f"openssl x509 -enddate -noout -in {cert_path}")
        if rc == 0:
            date_str = out.replace("notAfter=", "").strip()
            try:
                from datetime import datetime
                clean_date = date_str.replace("GMT", "").strip()
                expiry_dt = datetime.strptime(clean_date, "%b %d %H:%M:%S %Y")
                diff = expiry_dt - datetime.utcnow()
                if diff.days < 0:
                    status = "FAIL"
                    msg = f"mTLS Client Certificate is EXPIRED since {date_str}!"
                elif diff.days < 30:
                    status = "WARN"
                    msg = f"mTLS Client Certificate is expiring soon (in {diff.days} days) on {date_str}."
                else:
                    status = "PASS"
                    msg = f"mTLS Client Certificate is valid. Expires on {date_str} (in {diff.days} days)."
            except Exception as ex:
                status = "PASS"
                msg = f"mTLS Client Certificate exists. Expiration date: {date_str} (parse error: {str(ex)})."
        else:
            status = "FAIL"
            msg = f"Failed to check client certificate enddate: {err or out}"
    else:
        status = "FAIL"
        msg = f"mTLS Client Certificate not found at {cert_path}."
    results["mtls_cert_expiration"] = {
        "status": status,
        "output": msg
    }
    
    # 6b. Ingress Server Certificate Expiration Check
    update_current_check(category, "ingress_cert_expiration")
    cert_path = "/etc/hci/spectrum/certs/server.crt"
    if os.path.exists(cert_path):
        rc, out, err = run_cmd(f"openssl x509 -enddate -noout -in {cert_path}")
        if rc == 0:
            date_str = out.replace("notAfter=", "").strip()
            try:
                from datetime import datetime
                clean_date = date_str.replace("GMT", "").strip()
                expiry_dt = datetime.strptime(clean_date, "%b %d %H:%M:%S %Y")
                diff = expiry_dt - datetime.utcnow()
                if diff.days < 0:
                    status = "FAIL"
                    msg = f"Ingress Server Certificate is EXPIRED since {date_str}!"
                elif diff.days < 30:
                    status = "WARN"
                    msg = f"Ingress Server Certificate is expiring soon (in {diff.days} days) on {date_str}."
                else:
                    status = "PASS"
                    msg = f"Ingress Server Certificate is valid. Expires on {date_str} (in {diff.days} days)."
            except Exception as ex:
                status = "PASS"
                msg = f"Ingress Server Certificate exists. Expiration date: {date_str} (parse error: {str(ex)})."
        else:
            status = "FAIL"
            msg = f"Failed to check ingress certificate enddate: {err or out}"
    else:
        status = "FAIL"
        msg = f"Ingress Server Certificate not found at {cert_path}."
    results["ingress_cert_expiration"] = {
        "status": status,
        "output": msg
    }
    
    # 6bb. Certificate Seeding and Verification Check
    update_current_check(category, "certs_seeding_check")
    try:
        cert_groups = [
            {
                "name": "mTLS Client",
                "ca": "/root/.certs/ca.crt",
                "cert": "/root/.certs/client.crt",
                "key": "/root/.certs/client.key"
            },
            {
                "name": "Spark Daemon",
                "ca": "/etc/hci/spark/certs/ca.crt",
                "cert": "/etc/hci/spark/certs/node.crt",
                "key": "/etc/hci/spark/certs/node.key"
            },
            {
                "name": "Spectrum Ingress",
                "cert": "/etc/hci/spectrum/certs/server.crt",
                "key": "/etc/hci/spectrum/certs/server.key"
            }
        ]

        issues = []
        warnings = []
        checked = []

        for group in cert_groups:
            name = group["name"]
            ca_path = group.get("ca")
            cert_path = group["cert"]
            key_path = group["key"]

            # 1. Existence check
            missing = []
            if ca_path and not os.path.exists(ca_path):
                missing.append(f"CA Cert ({ca_path})")
            if not os.path.exists(cert_path):
                missing.append(f"Certificate ({cert_path})")
            if not os.path.exists(key_path):
                missing.append(f"Private Key ({key_path})")

            if missing:
                issues.append(f"{name} Certificate Group has missing components: {', '.join(missing)}")
                continue

            checked.append(name)

            # 2. Permissions check on private keys (should be 600 or 400)
            try:
                mode = os.stat(key_path).st_mode & 0o777
                if (mode & 0o077) != 0:
                    warnings.append(f"{name} Private Key ({key_path}) has insecure permissions: {oct(mode)} (expected 600 or 400)")
            except Exception as e:
                warnings.append(f"Failed to check permissions for {name} Private Key ({key_path}): {str(e)}")

            # 3. Modulus check (Certificate matches Private Key)
            cert_mod = ""
            key_mod = ""
            
            rc_c, out_c, err_c = run_cmd(f"openssl x509 -noout -modulus -in {cert_path}")
            if rc_c == 0:
                cert_mod = out_c.strip()
            else:
                issues.append(f"Failed to extract modulus from {name} Certificate ({cert_path}): {err_c or out_c}")
                continue

            rc_k, out_k, err_k = run_cmd(f"openssl pkey -noout -modulus -in {key_path}")
            if rc_k != 0:
                rc_k, out_k, err_k = run_cmd(f"openssl rsa -noout -modulus -in {key_path}")
            
            if rc_k == 0:
                key_mod = out_k.strip()
            else:
                issues.append(f"Failed to extract modulus from {name} Private Key ({key_path}): {err_k or out_k}")
                continue

            if cert_mod != key_mod:
                issues.append(f"{name} Certificate ({cert_path}) and Private Key ({key_path}) modulus mismatch! They do not form a valid pair.")
                continue

            # 4. CA Signature Verification
            if ca_path:
                rc_v, out_v, err_v = run_cmd(f"openssl verify -CAfile {ca_path} {cert_path}")
                if rc_v != 0:
                    issues.append(f"{name} Certificate ({cert_path}) failed validation against CA ({ca_path}): {err_v or out_v}")

        if issues:
            status = "FAIL"
            msg = "Certificate Seeding Verification FAILED:\n- " + "\n- ".join(issues)
            if warnings:
                msg += "\nWarnings:\n- " + "\n- ".join(warnings)
        elif warnings:
            status = "WARN"
            msg = "Certificate Seeding verified with warnings:\n- " + "\n- ".join(warnings)
        else:
            status = "PASS"
            msg = f"All certificate groups ({', '.join(checked)}) are correctly seeded, verified, and have secure private key permissions."

    except Exception as ex:
        status = "FAIL"
        msg = f"Error running Certificate Seeding Verification check: {str(ex)}"

    results["certs_seeding_check"] = {
        "status": status,
        "output": msg
    }

    # 6c. Slate Ingress Configurations Check
    update_current_check(category, "slate_config_status")
    traefik_yml = "/etc/hci/slate/traefik.yml"
    dynamic_yml = "/etc/hci/slate/dynamic.yml"
    if os.path.exists(traefik_yml) and os.path.exists(dynamic_yml):
        status = "PASS"
        msg = f"Slate configuration files exist at /etc/hci/slate/."
    else:
        status = "FAIL"
        msg = f"Slate configuration files missing! Checked {traefik_yml} and {dynamic_yml}."
    results["slate_config_status"] = {
        "status": status,
        "output": msg
    }
    
    # 7. Libvirt responsiveness check
    update_current_check(category, "libvirt_responsiveness")
    in_maint = os.path.exists("/etc/hci/maintenance.state")
    if in_maint:
        status = "PASS"
        msg = "[SKIPPED] Host is in maintenance mode; virtualization hypervisor is not expected to respond."
    else:
        rc, out, err = run_cmd("timeout 5 virsh -c qemu:///system list --all")
        if rc == 0:
            status = "PASS"
            msg = f"Virtualization hypervisor is responsive. virsh command succeeded:\n{out}"
        else:
            status = "FAIL"
            msg = f"Virtualization hypervisor is unresponsive or virsh failed (exit code {rc}):\n{err or out}"
    results["libvirt_responsiveness"] = {
        "status": status,
        "output": msg
    }
    
    # 8. Hostname resolution check
    update_current_check(category, "hostname_resolution")
    try:
        import socket
        hosts_info = []
        try:
            with open("/etc/hci/cluster.json", "r") as f:
                cdata = json.load(f)
                hosts_info = cdata.get("hosts", [])
        except Exception:
            pass
        
        if not hosts_info:
            status = "PASS"
            msg = "No cluster hosts configured in /etc/hci/cluster.json. Skipping name resolution check."
        else:
            failed_resolutions = []
            resolved_ips = []
            for h in hosts_info:
                hname = h.get("hostname")
                ip = h.get("ip")
                
                resolved = False
                errs = []
                
                # 1. Try to resolve the configured hostname
                if hname:
                    try:
                        resolved_ip = socket.gethostbyname(hname)
                        resolved_ips.append(f"Configured: {hname} -> {resolved_ip}")
                        resolved = True
                    except Exception as e:
                        errs.append(f"configured hostname '{hname}': {str(e)}")
                
                # 2. Try reverse lookup on IP and resolve the returned hostname
                if not resolved and ip:
                    try:
                        rev_hname, _, _ = socket.gethostbyaddr(ip)
                        resolved_ip = socket.gethostbyname(rev_hname)
                        resolved_ips.append(f"Reverse/Forward Fallback: {ip} -> {rev_hname} -> {resolved_ip}")
                        resolved = True
                    except Exception as e:
                        errs.append(f"reverse lookup fallback for IP '{ip}': {str(e)}")
                        
                if not resolved:
                    details = " AND ".join(errs)
                    failed_resolutions.append(f"{hname or ip} ({details})")
            
            if failed_resolutions:
                status = "WARN"
                msg = f"Failed to resolve name mappings for cluster nodes:\n" + "\n".join(failed_resolutions)
            else:
                status = "PASS"
                msg = f"All cluster node name mappings resolved successfully:\n" + "\n".join(resolved_ips)
    except Exception as e:
        status = "WARN"
        msg = f"Error executing hostname resolution check: {str(e)}"
    results["hostname_resolution"] = {
        "status": status,
        "output": msg
    }
    
    # 9. Spectrum privilege check
    update_current_check(category, "spectrum_privilege_check")
    in_maint = os.path.exists("/etc/hci/maintenance.state")
    rc_sp, out_sp, err_sp = run_cmd("podman inspect systemd-spectrum")
    if rc_sp == 0:
        try:
            inspect_data = json.loads(out_sp)
            if inspect_data and isinstance(inspect_data, list):
                container_info = inspect_data[0]
                host_config = container_info.get("HostConfig", {})
                privileged = host_config.get("Privileged", False)
                mounts = container_info.get("Mounts", [])
                
                has_libvirt_sock = False
                for m in mounts:
                    src = m.get("Source", "")
                    dst = m.get("Destination", "")
                    if "libvirt-sock" in src or "libvirt-sock" in dst:
                        has_libvirt_sock = True
                        break
                
                if privileged:
                    status = "WARN"
                    msg = "Spectrum container is running in PRIVILEGED mode (expected for host metrics)."
                elif has_libvirt_sock:
                    status = "WARN"
                    msg = "Spectrum container has a direct mount to the host libvirt socket (/var/run/libvirt/libvirt-sock), which bypasses Spark isolation!"
                else:
                    status = "PASS"
                    msg = "Spectrum container is running unprivileged and has no direct host libvirt socket mounts."
            else:
                status = "FAIL"
                msg = f"Unexpected podman inspect output structure: {out_sp}"
        except Exception as e:
            status = "FAIL"
            msg = f"Failed to parse podman inspect JSON: {str(e)}\nRaw output: {out_sp}"
    else:
        if in_maint:
            status = "PASS"
            msg = "[SKIPPED] Host is in maintenance mode; Spectrum container is not running."
        else:
            status = "FAIL"
            msg = f"Failed to execute podman inspect systemd-spectrum: {err_sp or out_sp}"
        
    results["spectrum_privilege_check"] = {
        "status": status,
        "output": msg
    }

    # 10. Authentication seeding check
    update_current_check(category, "auth_seeding_check")
    try:
        import socket
        local_ip = "127.0.0.1"
        try:
            s = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
            s.connect(("8.8.8.8", 80))
            local_ip = s.getsockname()[0]
            s.close()
        except Exception:
            pass
            
        cql_auth = "SELECT username FROM hydra.users;"
        rc_auth, out_auth, err_auth = run_cmd(f"podman exec -i systemd-hydra-db cqlsh {local_ip} -e \"{cql_auth}\"")
        if rc_auth == 0:
            if "helios" in out_auth.lower():
                status = "PASS"
                msg = "ScyllaDB authentication seeding is healthy: default user 'helios' is present."
            elif len(out_auth.strip().splitlines()) > 2:
                status = "PASS"
                msg = f"ScyllaDB authentication seeding is healthy: users are present in hydra.users.\n{out_auth}"
            else:
                status = "FAIL"
                msg = f"ScyllaDB authentication seeding failed: hydra.users table is empty.\n{out_auth}"
        else:
            status = "FAIL"
            msg = f"Failed to query hydra.users table from ScyllaDB: {err_auth or out_auth}"
    except Exception as e:
        status = "FAIL"
        msg = f"Error running authentication seeding check: {str(e)}"
        
    results["auth_seeding_check"] = {
        "status": status,
        "output": msg
    }
    
    # 11. VIP binding status
    update_current_check(category, "vip_binding_status")
    try:
        vip_status = "PASS"
        vip_msg = "VIP check passed."
        if os.path.exists("/etc/hci/cluster.json"):
            with open("/etc/hci/cluster.json", "r") as f:
                cdata = json.load(f)
            vip = cdata.get("vip")
            hosts = cdata.get("hosts", [])
            ips = [h.get("ip") for h in hosts if h.get("ip")]
            if vip:
                rc_ip, out_ip, _ = run_cmd("ip addr show")
                bound_locally = (vip in out_ip)
                
                # Use the exact same leadership logic as bifrost.py to find expected VIP owner
                # 1. Find raw ZooKeeper leader
                zk_leader_ip = None
                for ip in ips:
                    try:
                        import socket
                        s = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
                        s.settimeout(0.2)
                        s.connect((ip, 2181))
                        s.sendall(b"stat")
                        resp = s.recv(1024).decode('utf-8', errors='ignore')
                        s.close()
                        if "mode: leader" in resp.lower() or "mode: standalone" in resp.lower():
                            zk_leader_ip = ip
                            break
                    except Exception:
                        pass
                        
                # 2. Check if ZK leader is active on port 8443 (Spectrum)
                leader_active = False
                if zk_leader_ip:
                    try:
                        import socket
                        s = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
                        s.settimeout(0.2)
                        s.connect((zk_leader_ip, 8443))
                        s.close()
                        leader_active = True
                    except Exception:
                        leader_active = False
                        
                expected_vip_holder = None
                if leader_active:
                    expected_vip_holder = zk_leader_ip
                else:
                    # Fallback to candidates with port 8443 open
                    candidates = []
                    for ip in ips:
                        try:
                            import socket
                            s = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
                            s.settimeout(0.2)
                            s.connect((ip, 8443))
                            s.close()
                            candidates.append(ip)
                        except Exception:
                            pass
                    if candidates:
                        candidates.sort()
                        expected_vip_holder = candidates[0]
                    else:
                        expected_vip_holder = zk_leader_ip if zk_leader_ip else "127.0.0.1"
                        
                # Find local IP
                local_ip = "127.0.0.1"
                try:
                    import socket
                    s = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
                    s.connect(("8.8.8.8", 80))
                    local_ip = s.getsockname()[0]
                    s.close()
                except Exception:
                    pass
                    
                is_expected_holder = (local_ip == expected_vip_holder)
                
                if is_expected_holder:
                    if bound_locally:
                        vip_status = "PASS"
                        vip_msg = f"VIP {vip} is correctly bound locally on the expected active node ({expected_vip_holder})."
                    else:
                        vip_status = "FAIL"
                        vip_msg = f"VIP {vip} is NOT bound locally, but this node ({local_ip}) is the expected active node!"
                else:
                    if bound_locally:
                        vip_status = "FAIL"
                        vip_msg = f"Conflict: VIP {vip} is bound locally, but the expected active node is {expected_vip_holder}!"
                    else:
                        vip_status = "PASS"
                        vip_msg = f"VIP {vip} is not bound locally (correct behavior; expected active node is {expected_vip_holder})."
            else:
                vip_status = "PASS"
                vip_msg = "No VIP configured in cluster.json."
        else:
            vip_status = "WARN"
            vip_msg = "/etc/hci/cluster.json not found, skipping VIP check."
    except Exception as e:
        vip_status = "FAIL"
        vip_msg = f"Error checking VIP status: {str(e)}"
    results["vip_binding_status"] = {
        "status": vip_status,
        "output": vip_msg
    }

    # 12. Maintenance Mode Integrity
    update_current_check(category, "maintenance_mode_check")
    try:
        maint_status = "PASS"
        maint_msg = "Maintenance mode integrity is healthy."
        in_maint = os.path.exists("/etc/hci/maintenance.state")
        
        db_status = "NORMAL"
        import socket
        local_ip = "127.0.0.1"
        try:
            s = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
            s.connect(("8.8.8.8", 80))
            local_ip = s.getsockname()[0]
            s.close()
        except Exception:
            pass
            
        cql_nodes = "SELECT status, ip FROM hydra.nodes;"
        rc_nodes, out_nodes, _ = run_cmd(f"podman exec -i systemd-hydra-db cqlsh {local_ip} -e \"{cql_nodes}\" || true")
        if rc_nodes == 0 and out_nodes:
            for line in out_nodes.splitlines():
                if local_ip in line:
                    if "IN_MAINTENANCE" in line:
                        db_status = "IN_MAINTENANCE"
                    elif "ENTERING_MAINTENANCE" in line:
                        db_status = "ENTERING_MAINTENANCE"
                        
        if in_maint:
            running_vms = []
            rc_v, out_v, _ = run_cmd("virsh -c qemu:///system list --name --state-running")
            if rc_v == 0 and out_v.strip():
                running_vms = [v.strip() for v in out_v.strip().splitlines() if v.strip()]
            
            active_services = []
            services_to_check = ["spectrum", "catalyst", "bifrost", "dagur", "mimir", "vali", "linstor-controller", "gatoway", "urbosa", "logos", "mipha", "agahnim", "slate"]
            for svc in services_to_check:
                rc_svc, out_svc, _ = run_cmd(f"systemctl is-active {svc}")
                if rc_svc == 0 and out_svc.strip() == "active":
                    active_services.append(svc)
                    
            if running_vms:
                maint_status = "FAIL"
                maint_msg = f"Host is in maintenance mode but VMs are still running: {', '.join(running_vms)}"
            elif active_services:
                maint_status = "FAIL"
                maint_msg = f"Host is in maintenance mode but the following services are still active: {', '.join(active_services)}"
            else:
                maint_status = "PASS"
                maint_msg = "Host is in maintenance mode; all workloads are cleanly evacuated and stopped."
        else:
            if db_status == "IN_MAINTENANCE":
                maint_status = "FAIL"
                maint_msg = "DB reports host status as IN_MAINTENANCE, but /etc/hci/maintenance.state is missing!"
            else:
                maint_status = "PASS"
                maint_msg = "Host is in normal mode and active."
    except Exception as e:
        maint_status = "FAIL"
        maint_msg = f"Error checking maintenance status: {str(e)}"
    results["maintenance_mode_check"] = {
        "status": maint_status,
        "output": maint_msg
    }

    # 13. Vali Leader Status
    update_current_check(category, "vali_leader_status")
    try:
        vali_status = "PASS"
        vali_msg = "Vali placement manager leader status is healthy."
        
        hosts = []
        if os.path.exists("/etc/hci/cluster.json"):
            with open("/etc/hci/cluster.json", "r") as f:
                cdata = json.load(f)
                hosts = [h["ip"] for h in cdata.get("hosts", [])]
                
        active_vali_ip = None
        balance_score = "N/A"
        import urllib.request
        for ip in hosts:
            try:
                req = urllib.request.Request(f"http://{ip}:9095/api/v1/drs/status")
                with urllib.request.urlopen(req, timeout=2) as resp:
                    data = json.loads(resp.read().decode('utf-8'))
                    active_vali_ip = ip
                    balance_score = data.get('balance_score', 'N/A')
                    break
            except Exception:
