#!/usr/bin/env python3
import sys
import subprocess
import json
import os
import re
import time

def run_cmd(cmd):
    res = subprocess.run(cmd, shell=True, stdout=subprocess.PIPE, stderr=subprocess.PIPE)
    return res.returncode, res.stdout.decode('utf-8', errors='ignore').strip(), res.stderr.decode('utf-8', errors='ignore').strip()

def is_zookeeper_leader():
    try:
        import socket
        s = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
        s.settimeout(0.5)
        s.connect(("127.0.0.1", 2181))
        s.sendall(b"stat")
        resp = s.recv(1024).decode('utf-8', errors='ignore')
        s.close()
        return "mode: leader" in resp.lower()
    except Exception:
        return False

def update_current_check(category, check_name):
    try:
        with open(f"/tmp/mimir_check_{category}", "w") as f:
            f.write(check_name)
    except Exception:
        pass

def check_services(category):
    results = {}
    
    # 1. Systemd service statuses
    svcs = ["zookeeper", "hydra-db", "aether", "spectrum", "spark-daemon", "libvirtd", "bifrost"]
    for svc in svcs:
        update_current_check(category, f"{svc}_status")
        rc, out, err = run_cmd(f"systemctl is-active {svc}")
        status = "PASS" if out == "active" else "FAIL"
        if svc == "libvirtd" and status == "FAIL":
            rc_fallback, out_fallback, err_fallback = run_cmd("systemctl is-active virtqemud")
            if out_fallback == "active":
                status = "PASS"
                out = "active (virtqemud)"
                err = ""
        results[f"{svc}_status"] = {
            "status": status,
            "output": f"Service is {out}.\nSystemd Output:\n{out or err}"
        }
        
    # 2. ScyllaDB Ring status (using nodetool)
    update_current_check(category, "scylladb_ring_status")
    rc, out, err = run_cmd("nodetool status")
    if rc == 0:
        # Check if any nodes are Down or Joining
        dn_count = len(re.findall(r"^DN\s", out, re.MULTILINE))
        uj_count = len(re.findall(r"^UJ\s", out, re.MULTILINE))
        if dn_count > 0:
            status = "FAIL"
            msg = f"Detected {dn_count} DOWN node(s) in ScyllaDB ring!\n{out}"
        elif uj_count > 0:
            status = "WARN"
            msg = f"Detected {uj_count} joining node(s) in ScyllaDB ring.\n{out}"
        else:
            status = "PASS"
            msg = f"All ScyllaDB ring nodes are UP and Normal (UN).\n{out}"
    else:
        status = "FAIL"
        msg = f"Failed to execute nodetool status: {err or out}"
        
    results["scylladb_ring_status"] = {
        "status": status,
        "output": msg
    }
    
    # 3. ZooKeeper Consensus mode check
    update_current_check(category, "zookeeper_consensus")
    try:
        import socket
        s = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
        s.settimeout(1.0)
        s.connect(("127.0.0.1", 2181))
        s.sendall(b"stat")
        resp = s.recv(1024).decode('utf-8', errors='ignore')
        s.close()
        mode = "unknown"
        for line in resp.splitlines():
            if "mode:" in line.lower():
                mode = line.split(":")[-1].strip()
        if mode in ["leader", "follower"]:
            status = "PASS"
            msg = f"ZooKeeper is online and participating in consensus. Mode: {mode}."
        else:
            status = "WARN"
            msg = f"ZooKeeper is online but consensus mode is unexpected: {mode}.\nFull stat response:\n{resp}"
    except Exception as e:
        status = "FAIL"
        msg = f"Failed to connect to ZooKeeper on 127.0.0.1:2181: {str(e)}"
    results["zookeeper_consensus"] = {
        "status": status,
        "output": msg
    }
    
    # 4. ScyllaDB Keyspace Replication Check
    update_current_check(category, "scylladb_replication")
    try:
        import socket
        local_ip = "127.0.0.1"
        try:
            s = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
            s.connect(("8.8.8.8", 80))
            local_ip = s.getsockname()[0]
            s.close()
        except Exception:
            pass
        cql = "SELECT replication FROM system_schema.keyspaces WHERE keyspace_name = 'hydra';"
        rc, out, err = run_cmd("podman exec -i systemd-hydra-db cqlsh " + local_ip + " -e \"" + cql + "\"")
        if rc == 0 and "replication_factor" in out:
            if "'replication_factor': '3'" in out or "replication_factor': '3'" in out or "'3'" in out:
                status = "PASS"
                msg = f"Keyspace 'hydra' is configured with replication factor 3.\n{out}"
            else:
                status = "WARN"
                msg = f"Keyspace 'hydra' replication configuration is unexpected:\n{out}"
        else:
            status = "FAIL"
            msg = f"Failed to query keyspace replication: {err or out}"
    except Exception as e:
        status = "FAIL"
        msg = f"Failed to run ScyllaDB replication check: {str(e)}"
    results["scylladb_replication"] = {
        "status": status,
        "output": msg
    }
    
    # 5. Spectrum port reachability
    update_current_check(category, "spectrum_api_port")
    try:
        import socket
        s = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
        s.settimeout(1.0)
        s.connect(("127.0.0.1", 8443))
        s.close()
        status = "PASS"
        msg = "Spectrum API Web Console port 8443 is open and accepting TCP connections."
    except Exception as e:
        status = "FAIL"
        msg = f"Failed to connect to Spectrum API on port 8443: {str(e)}"
    results["spectrum_api_port"] = {
        "status": status,
        "output": msg
    }
    
    # 6. mTLS Client Certificate Expiration Check
    update_current_check(category, "mtls_cert_expiration")
    cert_path = "/root/.certs/client.crt"
    if os.path.exists(cert_path):
        rc, out, err = run_cmd(f"openssl x509 -enddate -noout -in {cert_path}")
        if rc == 0:
            date_str = out.replace("notAfter=", "").strip()
            try:
                from datetime import datetime
                clean_date = date_str.replace("GMT", "").strip()
                expiry_dt = datetime.strptime(clean_date, "%b %d %H:%M:%S %Y")
                diff = expiry_dt - datetime.utcnow()
                if diff.days < 0:
                    status = "FAIL"
                    msg = f"mTLS Client Certificate is EXPIRED since {date_str}!"
                elif diff.days < 30:
                    status = "WARN"
                    msg = f"mTLS Client Certificate is expiring soon (in {diff.days} days) on {date_str}."
                else:
                    status = "PASS"
                    msg = f"mTLS Client Certificate is valid. Expires on {date_str} (in {diff.days} days)."
            except Exception as ex:
                status = "PASS"
                msg = f"mTLS Client Certificate exists. Expiration date: {date_str} (parse error: {str(ex)})."
        else:
            status = "FAIL"
            msg = f"Failed to check client certificate enddate: {err or out}"
    else:
        status = "FAIL"
        msg = f"mTLS Client Certificate not found at {cert_path}."
    results["mtls_cert_expiration"] = {
        "status": status,
        "output": msg
    }
    
    # 7. Libvirt responsiveness check
    update_current_check(category, "libvirt_responsiveness")
    rc, out, err = run_cmd("timeout 5 virsh -c qemu:///system list --all")
    if rc == 0:
        status = "PASS"
        msg = f"Virtualization hypervisor is responsive. virsh command succeeded:\n{out}"
    else:
        status = "FAIL"
        msg = f"Virtualization hypervisor is unresponsive or virsh failed (exit code {rc}):\n{err or out}"
    results["libvirt_responsiveness"] = {
        "status": status,
        "output": msg
    }
    
    # 8. Hostname resolution check
    update_current_check(category, "hostname_resolution")
    try:
        import socket
        hosts_info = []
        try:
            with open("/etc/hci/cluster.json", "r") as f:
                cdata = json.load(f)
                hosts_info = cdata.get("hosts", [])
        except Exception:
            pass
        
        if not hosts_info:
            status = "PASS"
            msg = "No cluster hosts configured in /etc/hci/cluster.json. Skipping name resolution check."
        else:
            failed_resolutions = []
            resolved_ips = []
            for h in hosts_info:
                hname = h.get("hostname")
                ip = h.get("ip")
                
                resolved = False
                errs = []
                
                # 1. Try to resolve the configured hostname
                if hname:
                    try:
                        resolved_ip = socket.gethostbyname(hname)
                        resolved_ips.append(f"Configured: {hname} -> {resolved_ip}")
                        resolved = True
                    except Exception as e:
                        errs.append(f"configured hostname '{hname}': {str(e)}")
                
                # 2. Try reverse lookup on IP and resolve the returned hostname
                if not resolved and ip:
                    try:
                        rev_hname, _, _ = socket.gethostbyaddr(ip)
                        resolved_ip = socket.gethostbyname(rev_hname)
                        resolved_ips.append(f"Reverse/Forward Fallback: {ip} -> {rev_hname} -> {resolved_ip}")
                        resolved = True
                    except Exception as e:
                        errs.append(f"reverse lookup fallback for IP '{ip}': {str(e)}")
                        
                if not resolved:
                    details = " AND ".join(errs)
                    failed_resolutions.append(f"{hname or ip} ({details})")
            
            if failed_resolutions:
                status = "FAIL"
                msg = f"Failed to resolve name mappings for cluster nodes:\n" + "\n".join(failed_resolutions)
            else:
                status = "PASS"
                msg = f"All cluster node name mappings resolved successfully:\n" + "\n".join(resolved_ips)
    except Exception as e:
        status = "FAIL"
        msg = f"Error executing hostname resolution check: {str(e)}"
    results["hostname_resolution"] = {
        "status": status,
        "output": msg
    }
    
    # 9. Spectrum privilege check
    update_current_check(category, "spectrum_privilege_check")
    rc_sp, out_sp, err_sp = run_cmd("podman inspect systemd-spectrum")
    if rc_sp == 0:
        try:
            inspect_data = json.loads(out_sp)
            if inspect_data and isinstance(inspect_data, list):
                container_info = inspect_data[0]
                host_config = container_info.get("HostConfig", {})
                privileged = host_config.get("Privileged", False)
                mounts = container_info.get("Mounts", [])
                
                has_libvirt_sock = False
                for m in mounts:
                    src = m.get("Source", "")
                    dst = m.get("Destination", "")
                    if "libvirt-sock" in src or "libvirt-sock" in dst:
                        has_libvirt_sock = True
                        break
                
                if privileged:
                    status = "FAIL"
                    msg = "Spectrum container is running in PRIVILEGED mode, which is a security risk!"
                elif has_libvirt_sock:
                    status = "FAIL"
                    msg = "Spectrum container has a direct mount to the host libvirt socket (/var/run/libvirt/libvirt-sock), which bypasses Spark isolation!"
                else:
                    status = "PASS"
                    msg = "Spectrum container is running unprivileged and has no direct host libvirt socket mounts."
            else:
                status = "FAIL"
                msg = f"Unexpected podman inspect output structure: {out_sp}"
        except Exception as e:
            status = "FAIL"
            msg = f"Failed to parse podman inspect JSON: {str(e)}\nRaw output: {out_sp}"
    else:
        status = "FAIL"
        msg = f"Failed to execute podman inspect systemd-spectrum: {err_sp or out_sp}"
        
    results["spectrum_privilege_check"] = {
        "status": status,
        "output": msg
    }

    # 10. Authentication seeding check
    update_current_check(category, "auth_seeding_check")
    try:
        import socket
        local_ip = "127.0.0.1"
        try:
            s = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
            s.connect(("8.8.8.8", 80))
            local_ip = s.getsockname()[0]
            s.close()
        except Exception:
            pass
            
        cql_auth = "SELECT username FROM hydra.users;"
        rc_auth, out_auth, err_auth = run_cmd(f"podman exec -i systemd-hydra-db cqlsh {local_ip} -e \"{cql_auth}\"")
        if rc_auth == 0:
            if "helios" in out_auth.lower():
                status = "PASS"
                msg = "ScyllaDB authentication seeding is healthy: default user 'helios' is present."
            elif len(out_auth.strip().splitlines()) > 2:
                status = "PASS"
                msg = f"ScyllaDB authentication seeding is healthy: users are present in hydra.users.\n{out_auth}"
            else:
                status = "FAIL"
                msg = f"ScyllaDB authentication seeding failed: hydra.users table is empty.\n{out_auth}"
        else:
            status = "FAIL"
            msg = f"Failed to query hydra.users table from ScyllaDB: {err_auth or out_auth}"
    except Exception as e:
        status = "FAIL"
        msg = f"Error running authentication seeding check: {str(e)}"
        
    results["auth_seeding_check"] = {
        "status": status,
        "output": msg
    }
    
    # 11. VIP binding status
    update_current_check(category, "vip_binding_status")
    try:
        vip_status = "PASS"
        vip_msg = "VIP check passed."
        if os.path.exists("/etc/hci/cluster.json"):
            with open("/etc/hci/cluster.json", "r") as f:
                cdata = json.load(f)
            vip = cdata.get("vip")
            hosts = [h["ip"] for h in cdata.get("hosts", [])]
            if vip:
                rc_ip, out_ip, _ = run_cmd("ip addr show")
                bound_locally = (vip in out_ip)
                local_leader = is_zookeeper_leader()
                
                if local_leader:
                    if bound_locally:
                        vip_status = "PASS"
                        vip_msg = f"VIP {vip} is correctly bound locally on the ZooKeeper leader."
                    else:
                        vip_status = "FAIL"
                        vip_msg = f"VIP {vip} is NOT bound locally, but this node is the ZooKeeper leader!"
                else:
                    if bound_locally:
                        vip_status = "FAIL"
                        vip_msg = f"Conflict: VIP {vip} is bound locally, but this node is a ZooKeeper follower!"
                    else:
                        vip_status = "PASS"
                        vip_msg = f"VIP {vip} is not bound locally (correct behavior for ZooKeeper follower)."
            else:
                vip_status = "PASS"
                vip_msg = "No VIP configured in cluster.json."
        else:
            vip_status = "WARN"
            vip_msg = "/etc/hci/cluster.json not found, skipping VIP check."
    except Exception as e:
        vip_status = "FAIL"
        vip_msg = f"Error checking VIP status: {str(e)}"
    results["vip_binding_status"] = {
        "status": vip_status,
        "output": vip_msg
    }

    # 12. Maintenance Mode Integrity
    update_current_check(category, "maintenance_mode_check")
    try:
        maint_status = "PASS"
        maint_msg = "Maintenance mode integrity is healthy."
        in_maint = os.path.exists("/etc/hci/maintenance.state")
        
        db_status = "NORMAL"
        import socket
        local_ip = "127.0.0.1"
        try:
            s = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
            s.connect(("8.8.8.8", 80))
            local_ip = s.getsockname()[0]
            s.close()
        except Exception:
            pass
            
        cql_nodes = "SELECT status, ip FROM hydra.nodes;"
        rc_nodes, out_nodes, _ = run_cmd(f"podman exec -i systemd-hydra-db cqlsh {local_ip} -e \"{cql_nodes}\" || true")
        if rc_nodes == 0 and out_nodes:
            for line in out_nodes.splitlines():
                if local_ip in line:
                    if "IN_MAINTENANCE" in line:
                        db_status = "IN_MAINTENANCE"
                    elif "ENTERING_MAINTENANCE" in line:
                        db_status = "ENTERING_MAINTENANCE"
                        
        if in_maint:
            running_vms = []
            rc_v, out_v, _ = run_cmd("virsh -c qemu:///system list --name --state-running")
            if rc_v == 0 and out_v.strip():
                running_vms = [v.strip() for v in out_v.strip().splitlines() if v.strip()]
            
            active_services = []
            services_to_check = ["zookeeper", "hydra-db", "spectrum", "bifrost", "dagur", "mimir", "vali", "aether"]
            for svc in services_to_check:
                rc_svc, out_svc, _ = run_cmd(f"systemctl is-active {svc}")
                if rc_svc == 0 and out_svc.strip() == "active":
                    active_services.append(svc)
                    
            if running_vms:
                maint_status = "FAIL"
                maint_msg = f"Host is in maintenance mode but VMs are still running: {', '.join(running_vms)}"
            elif active_services:
                maint_status = "FAIL"
                maint_msg = f"Host is in maintenance mode but the following services are still active: {', '.join(active_services)}"
            else:
                maint_status = "PASS"
                maint_msg = "Host is in maintenance mode; all workloads are cleanly evacuated and stopped."
        else:
            if db_status == "IN_MAINTENANCE":
                maint_status = "FAIL"
                maint_msg = "DB reports host status as IN_MAINTENANCE, but /etc/hci/maintenance.state is missing!"
            else:
                maint_status = "PASS"
                maint_msg = "Host is in normal mode and active."
    except Exception as e:
        maint_status = "FAIL"
        maint_msg = f"Error checking maintenance status: {str(e)}"
    results["maintenance_mode_check"] = {
        "status": maint_status,
        "output": maint_msg
    }

    # 13. Vali Leader Status
    update_current_check(category, "vali_leader_status")
    try:
        vali_status = "PASS"
        vali_msg = "Vali placement manager leader status is healthy."
        
        hosts = []
        if os.path.exists("/etc/hci/cluster.json"):
            with open("/etc/hci/cluster.json", "r") as f:
                cdata = json.load(f)
                hosts = [h["ip"] for h in cdata.get("hosts", [])]
                
        leader_ip = None
        for ip in hosts:
            try:
                import socket
                s = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
                s.settimeout(0.5)
                s.connect((ip, 2181))
                s.sendall(b"stat")
                resp = s.recv(1024).decode('utf-8', errors='ignore')
                s.close()
                if "mode: leader" in resp.lower():
                    leader_ip = ip
                    break
            except:
                pass
                
        if leader_ip:
            import urllib.request
            try:
                req = urllib.request.Request(f"http://{leader_ip}:9095/api/v1/drs/status")
                with urllib.request.urlopen(req, timeout=5) as resp:
                    data = json.loads(resp.read().decode('utf-8'))
                    vali_msg = f"Vali is active on leader node {leader_ip}. DRS Score: {data.get('balance_score', 'N/A')}%"
            except Exception as e:
                vali_status = "FAIL"
                vali_msg = f"Vali manager leader {leader_ip} port 9095 is unresponsive: {e}"
        else:
            vali_status = "FAIL"
            vali_msg = "No active ZooKeeper leader node could be reached in the cluster."
    except Exception as e:
        vali_status = "FAIL"
        vali_msg = f"Error checking Vali leader status: {str(e)}"
    results["vali_leader_status"] = {
        "status": vali_status,
        "output": vali_msg
    }

    # 14. ScyllaDB Tasks Schema
    update_current_check(category, "scylladb_tasks_schema")
    try:
        db_schema_status = "PASS"
        db_schema_msg = "ScyllaDB task schemas and node tables are queryable."
        
        import socket
        local_ip = "127.0.0.1"
        try:
            s = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
            s.connect(("8.8.8.8", 80))
            local_ip = s.getsockname()[0]
            s.close()
        except Exception:
            pass
            
        missing = []
        for table in ["vali_tasks", "nodes", "vali_drs_history"]:
            cql_check = f"SELECT * FROM hydra.{table} LIMIT 1;"
            rc, _, err = run_cmd(f"podman exec -i systemd-hydra-db cqlsh {local_ip} -e \"{cql_check}\"")
            if rc != 0:
                missing.append(table)
        
        if missing:
            db_schema_status = "FAIL"
            db_schema_msg = f"The following tables are missing or not queryable in ScyllaDB: {', '.join(missing)}"
    except Exception as e:
        db_schema_status = "FAIL"
        db_schema_msg = f"Error checking ScyllaDB schemas: {str(e)}"
    results["scylladb_tasks_schema"] = {
        "status": db_schema_status,
        "output": db_schema_msg
    }

    # 15. Security Configuration Audit
    update_current_check(category, "security_config_audit")
    try:
        sec_status = "PASS"
        sec_msg = "Security audit passed. Default credentials for user 'helios' have been changed."
        
        import socket
        local_ip = "127.0.0.1"
        try:
            s = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
            s.connect(("8.8.8.8", 80))
            local_ip = s.getsockname()[0]
            s.close()
        except Exception:
            pass
            
        cql_pw = "SELECT JSON password_hash FROM hydra.users WHERE username = 'helios';"
        rc, out, err = run_cmd(f"podman exec -i systemd-hydra-db cqlsh {local_ip} -e \"{cql_pw}\"")
        if rc == 0:
            pw_hash = None
            for line in out.splitlines():
                line = line.strip()
                if line.startswith("{") and line.endswith("}"):
                    try:
                      j = json.loads(line)
                      pw_hash = j.get("password_hash")
                    except:
                      pass
            if pw_hash:
                is_default = False
                try:
                    parts = pw_hash.split('$')
                    if len(parts) == 4:
                        algo, iterations, salt, hash_b64 = parts
                        if algo == "pbkdf2_sha256":
                            import hashlib, base64, secrets
                            iterations = int(iterations)
                            hash_bytes = hashlib.pbkdf2_hmac('sha256', b'helios', salt.encode('utf-8'), iterations)
                            expected_b64 = base64.b64encode(hash_bytes).decode('utf-8')
                            is_default = secrets.compare_digest(hash_b64, expected_b64)
                except Exception as e:
                    pass
                
                if is_default:
                    sec_status = "WARN"
                    sec_msg = "Security risk: Default administrator account 'helios' is still using the default password 'helios'. Please change it immediately."
            else:
                sec_status = "PASS"
                sec_msg = "Default administrator account 'helios' password hash not found or changed."
        else:
            rc_db, out_db, _ = run_cmd("systemctl is-active hydra-db")
            if rc_db == 0 and out_db.strip() == "active":
                sec_status = "FAIL"
                sec_msg = f"Failed to query users table for password audit: {err or out}"
            else:
                sec_status = "PASS"
                sec_msg = "ScyllaDB is inactive on this host (maintenance mode). Skipping credentials audit."
    except Exception as e:
        sec_status = "FAIL"
        sec_msg = f"Error performing security audit: {str(e)}"
    results["security_config_audit"] = {
        "status": sec_status,
        "output": sec_msg
    }
    
    # 22. Powered Off VMs check
    update_current_check(category, "virsh_power_off_check")
    try:
        rc, out, err = run_cmd("virsh list --all")
        if rc == 0:
            powered_off_vms = []
            for line in out.splitlines():
                if "shut off" in line or "powered off" in line:
                    parts = line.split()
                    if len(parts) >= 2:
                        powered_off_vms.append(parts[1])
            if powered_off_vms:
                results["virsh_power_off_check"] = {
                    "status": "WARN",
                    "output": f"Found powered-off virtual machines in virsh: {', '.join(powered_off_vms)}.\nPowered off VMs should not exist in virsh list (they should be undefined when powered off)."
                }
            else:
                results["virsh_power_off_check"] = {
                    "status": "PASS",
                    "output": "No powered-off virtual machines found in virsh. All configured VMs are in active state."
                }
        else:
            results["virsh_power_off_check"] = {
                "status": "FAIL",
                "output": f"Failed to query virsh VM list: {err or out}"
            }
    except Exception as e:
        results["virsh_power_off_check"] = {
            "status": "FAIL",
            "output": f"Error during virsh power off check: {str(e)}"
        }

    # 23. Stuck Catalyst Tasks check
    update_current_check(category, "stuck_tasks_check")
    try:
        local_ip = "127.0.0.1"
        try:
            s = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
            s.connect(("8.8.8.8", 80))
            local_ip = s.getsockname()[0]
            s.close()
        except Exception:
            pass
        
        cql = "SELECT JSON task_id, service, action, status, created_at FROM hydra.catalyst_tasks;"
        rc, out, err = run_cmd(f"podman exec -i systemd-hydra-db cqlsh {local_ip} -e \"{cql}\"")
        if rc == 0:
            stuck_tasks = []
            now_ms = int(time.time() * 1000)
            for line in out.splitlines():
                line = line.strip()
                if line.startswith("{") and line.endswith("}"):
                    try:
                        task = json.loads(line)
                        status = task.get("status")
                        created_at = task.get("created_at")
                        if status in ["pending", "processing"] and created_at:
                            if now_ms - int(created_at) > 10 * 60 * 1000:
                                stuck_tasks.append(f"{task.get('task_id')} ({task.get('service')} - {task.get('action')})")
                    except Exception:
                        pass
            if stuck_tasks:
                results["stuck_tasks_check"] = {
                    "status": "WARN",
                    "output": f"Found stuck Catalyst tasks: {', '.join(stuck_tasks)}.\nThese tasks have been pending or processing for more than 10 minutes."
                }
            else:
                results["stuck_tasks_check"] = {
                    "status": "PASS",
                    "output": "No stuck Catalyst tasks found. All pending or processing tasks are running within normal duration thresholds."
                }
        else:
            results["stuck_tasks_check"] = {
                "status": "FAIL",
                "output": f"Failed to query catalyst tasks: {err or out}"
            }
    except Exception as e:
        results["stuck_tasks_check"] = {
            "status": "FAIL",
            "output": f"Error during stuck tasks check: {str(e)}"
        }

    return results

def check_storage(category):
    results = {}
    
    # 1. Aether peer status
    update_current_check(category, "gluster_peers")
    rc, out, err = run_cmd("podman exec systemd-aether gluster peer status")
    if rc == 0:
        # Check if there are disconnected peers
        disconnected = "State: Peer Rejected" in out or "State: Disconnected" in out
        status = "FAIL" if disconnected else "PASS"
        msg = out if out else "No peers configured (Single-node cluster or peering pending)."
    else:
        status = "FAIL"
        msg = f"Failed to query Aether peer status: {err or out}"
    results["gluster_peers"] = {
        "status": status,
        "output": msg
    }
    
    # 2. Aether volume status
    update_current_check(category, "gluster_volume")
    rc, out, err = run_cmd("podman exec systemd-aether gluster volume info")
    if rc == 0:
        down_vols = [v for v in out.splitlines() if "Status: Stopped" in v]
        status = "FAIL" if down_vols else "PASS"
        msg = out if out else "No active Aether volumes found."
    else:
        status = "FAIL"
        msg = f"Failed to query Aether volume info: {err or out}"
    results["gluster_volume"] = {
        "status": status,
        "output": msg
    }
    
    # 3. Disk brick mount check
    update_current_check(category, "brick_mounts")
    brick_dir = "/var/lib/hci/aether/bricks"
    status = "PASS"
    msg = "All expected bricks are mounted."
    
    expected_mounts = []
    if os.path.exists("/etc/fstab"):
        try:
            with open("/etc/fstab", "r") as f:
                for line in f:
                    line = line.strip()
                    if not line or line.startswith("#"):
                        continue
                    parts = line.split()
                    if len(parts) >= 2 and parts[1].startswith("/var/lib/hci/aether/bricks/"):
                        expected_mounts.append(parts[1])
        except Exception:
            pass

    if not expected_mounts:
        if os.path.exists(brick_dir):
            expected_mounts = [os.path.join(brick_dir, d) for d in os.listdir(brick_dir) if os.path.isdir(os.path.join(brick_dir, d))]

    if not expected_mounts:
        status = "FAIL"
        msg = f"ERROR: No brick mount points found in /etc/fstab or {brick_dir}"
    else:
        failed_mounts = []
        for mnt in expected_mounts:
            rc_m, out_m, err_m = run_cmd(f"findmnt {mnt}")
            if rc_m != 0:
                failed_mounts.append(mnt)
        if failed_mounts:
            status = "FAIL"
            msg = f"ERROR: The following brick directories are NOT mounted: {', '.join(failed_mounts)}"
        else:
            status = "PASS"
            msg = f"Brick disk partition mount points active: {', '.join(expected_mounts)}"
    results["brick_mounts"] = {
        "status": status,
        "output": msg
    }
    
    # 4. Storage volume capacity check
    update_current_check(category, "storage_capacity")
    vol_path = "/var/lib/hci/aether/volumes/default-vm-container"
    if os.path.exists(vol_path):
        try:
            stat = os.statvfs(vol_path)
            total = stat.f_blocks * stat.f_frsize
            free = stat.f_bavail * stat.f_frsize
            used = total - free
            pct = (used / total) * 100 if total > 0 else 0
            
            status = "PASS"
            if pct > 90.0:
                status = "FAIL"
            elif pct > 80.0:
                status = "WARN"
            
            msg = f"Volume Path: {vol_path}\nTotal Space: {total // 1024**3} GB\nUsed Space: {used // 1024**3} GB ({pct:.1f}% used)\nFree Space: {free // 1024**3} GB"
        except Exception as e:
            status = "FAIL"
            msg = f"Failed to check storage path statistics: {str(e)}"
    else:
        status = "FAIL"
        msg = f"Volume path {vol_path} does not exist or is not mounted."
        
    results["storage_capacity"] = {
        "status": status,
        "output": msg
    }
    
    # 5. Aether Split Brain Check
    update_current_check(category, "glusterfs_split_brain")
    rc, out, err = run_cmd("podman exec systemd-aether gluster volume heal default-vm-container info split-brain")
    if rc == 0:
        sb_count = 0
        for line in out.splitlines():
            if "split-brain" in line.lower() or "entries:" in line.lower():
                try:
                    parts = line.split(":")
                    if len(parts) >= 2:
                        val = int(parts[-1].strip())
                        sb_count += val
                except Exception:
                    pass
        if sb_count > 0:
            status = "FAIL"
            msg = f"Detected {sb_count} file(s) in split-brain state!\n{out}"
        else:
            status = "PASS"
            msg = f"No Aether split-brain files detected.\n{out}"
    else:
        combined = (err or "") + " " + (out or "")
        if "is not of type replicate" in combined:
            status = "PASS"
            msg = f"Skipped: Volume default-vm-container is of type disperse (split-brain checks are only valid for replicated volumes).\n{combined.strip()}"
        else:
            status = "FAIL"
            msg = f"Failed to query split-brain status: {err or out}"
    results["glusterfs_split_brain"] = {
        "status": status,
        "output": msg
    }
    
    # 6. Aether Heal Pending Check
    update_current_check(category, "glusterfs_heal_pending")
    rc, out, err = run_cmd("podman exec systemd-aether gluster volume heal default-vm-container info")
    if rc == 0:
        entries = 0
        for line in out.splitlines():
            if "number of entries:" in line.lower():
                try:
                    val = int(line.split(":")[-1].strip())
                    entries += val
                except Exception:
                    pass
        if entries > 0:
            status = "WARN"
            msg = f"There are {entries} pending file(s) in Aether healing queue.\n{out}"
        else:
            status = "PASS"
            msg = f"Aether heal queue is clean (0 pending entries).\n{out}"
    else:
        status = "FAIL"
        msg = f"Failed to query heal info: {err or out}"
    results["glusterfs_heal_pending"] = {
        "status": status,
        "output": msg
    }
    
    # 7. Brick Space Utilization Check
    update_current_check(category, "brick_space_utilization")
    brick_dir = "/var/lib/hci/aether/bricks"
    expected_mounts = []
    if os.path.exists("/etc/fstab"):
        try:
            with open("/etc/fstab", "r") as f:
                for line in f:
                    line = line.strip()
                    if not line or line.startswith("#"):
                        continue
                    parts = line.split()
                    if len(parts) >= 2 and parts[1].startswith("/var/lib/hci/aether/bricks/"):
                        expected_mounts.append(parts[1])
        except Exception:
            pass

    if not expected_mounts:
        if os.path.exists(brick_dir):
            expected_mounts = [os.path.join(brick_dir, d) for d in os.listdir(brick_dir) if os.path.isdir(os.path.join(brick_dir, d))]

    if not expected_mounts:
        status = "FAIL"
        msg = f"No brick mount points found in /etc/fstab or {brick_dir}."
    else:
        brick_stats = []
        status = "PASS"
        for sd in expected_mounts:
            rc_m, _, _ = run_cmd(f"findmnt {sd}")
            if rc_m != 0:
                continue
            try:
                stat = os.statvfs(sd)
                total = stat.f_blocks * stat.f_frsize
                free = stat.f_bavail * stat.f_frsize
                used = total - free
                pct = (used / total) * 100 if total > 0 else 0
                
                brick_stats.append(f"Brick: {sd} | Total: {total // 1024**3} GB | Used: {used // 1024**3} GB ({pct:.1f}% used)")
                if pct > 90.0:
                    status = "FAIL"
                elif pct > 80.0 and status != "FAIL":
                    status = "WARN"
            except Exception as e:
                brick_stats.append(f"Brick: {sd} | Error querying space: {str(e)}")
                status = "FAIL"
        
        if not brick_stats:
            status = "FAIL"
            msg = f"No active mounted bricks found to check capacity."
        else:
            msg = "\n".join(brick_stats)
                
    results["brick_space_utilization"] = {
        "status": status,
        "output": msg
    }
    
    # 8. Storage Mount Options Check
    update_current_check(category, "storage_mount_options")
    vol_path = "/var/lib/hci/aether/volumes/default-vm-container"
    rc_m, out_m, err_m = run_cmd(f"findmnt -o OPTIONS -n {vol_path}")
    if rc_m != 0:
        status = "FAIL"
        msg = f"Storage volume path {vol_path} is not mounted."
    else:
        options = [opt.strip() for opt in out_m.split(",")]
        if "ro" in options:
            status = "FAIL"
            msg = f"CRITICAL: Storage volume {vol_path} is mounted READ-ONLY! Active options: {out_m}"
        else:
            status = "PASS"
            msg = f"Storage volume is mounted read-write (rw). Options: {out_m}"
            
    results["storage_mount_options"] = {
        "status": status,
        "output": msg
    }
    
    # 9. Storage Volume Writable Check
    update_current_check(category, "storage_volume_writable")
    vol_path = "/var/lib/hci/aether/volumes/default-vm-container"
    test_file = os.path.join(vol_path, ".mimir_rw_check")
    status = "PASS"
    msg = "Successfully verified read-write operations on the storage volume."
    
    if not os.path.exists(vol_path):
        status = "FAIL"
        msg = f"Volume path {vol_path} does not exist."
    else:
        try:
            import uuid
            test_content = f"mimir-test-{uuid.uuid4()}"
            with open(test_file, "w") as f:
                f.write(test_content)
                f.flush()
                os.fsync(f.fileno())
            
            with open(test_file, "r") as f:
                read_back = f.read().strip()
                
            if read_back != test_content:
                status = "FAIL"
                msg = f"Read-write verification failed: read data did not match written data."
            
            os.remove(test_file)
        except Exception as e:
            status = "FAIL"
            msg = f"Failed to perform write-read check on storage volume: {str(e)}"
            if os.path.exists(test_file):
                try:
                    os.remove(test_file)
                except Exception:
                    pass
                    
    results["storage_volume_writable"] = {
        "status": status,
        "output": msg
    }
    
    # 10. /etc/fstab safety check
    update_current_check(category, "fstab_safety_check")
    status = "PASS"
    msg = "No brick mount entries found in /etc/fstab."
    
    try:
        with open("/etc/fstab", "r") as f:
            lines = f.readlines()
            
        brick_entries = []
        for line in lines:
            line = line.strip()
            if not line or line.startswith("#"):
                continue
            parts = line.split()
            if len(parts) >= 4 and "/var/lib/hci/aether/bricks/" in parts[1]:
                brick_entries.append((parts[0], parts[1], parts[3]))
                
        if brick_entries:
            failed_safety = []
            for spec, mnt, opts in brick_entries:
                opt_list = opts.split(",")
                has_uuid = spec.startswith("UUID=")
                has_nofail = "nofail" in opt_list
                has_timeout = "x-systemd.device-timeout=5s" in opt_list or any("x-systemd.device-timeout" in o for o in opt_list)
                
                issues = []
                if not has_uuid:
                    issues.append("uses raw device path instead of UUID")
                if not has_nofail:
                    issues.append("missing 'nofail' flag")
                if not has_timeout:
                    issues.append("missing 'x-systemd.device-timeout=5s' flag")
                    
                if issues:
                    failed_safety.append(f"Mount {mnt} ({spec}): " + ", ".join(issues))
                    
            if failed_safety:
                status = "FAIL"
                msg = "The following fstab brick mounts do not meet safety requirements:\n" + "\n".join(failed_safety)
            else:
                status = "PASS"
                msg = f"All {len(brick_entries)} fstab brick mount(s) use UUIDs and contain safe timeout/recovery flags."
    except Exception as e:
        status = "FAIL"
        msg = f"Failed to read or parse /etc/fstab: {str(e)}"
        
    # 11. Orphaned Disks check
    update_current_check(category, "orphaned_disks_check")
    try:
        import glob
        local_ip = "127.0.0.1"
        try:
            with open("/etc/hci/spectrum/spectrum.env", "r") as f:
                for line in f:
                    if "=" in line:
                        k, v = line.strip().split("=", 1)
                        if k == "LOCAL_HYPERVISOR_IP":
                            local_ip = v.strip()
        except Exception:
            pass
            
        if local_ip == "127.0.0.1":
            try:
                s = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
                s.connect(("8.8.8.8", 80))
                local_ip = s.getsockname()[0]
                s.close()
            except Exception:
                pass
        
        cql = "SELECT JSON name FROM hydra.vms;"
        rc, out, err = run_cmd(f"podman exec -i systemd-hydra-db cqlsh {local_ip} -e \"{cql}\"")
        active_vms = set()
        if rc == 0:
            for line in out.splitlines():
                line = line.strip()
                if line.startswith("{") and line.endswith("}"):
                    try:
                        vm = json.loads(line)
                        if vm.get("name"):
                            active_vms.add(vm.get("name"))
                    except Exception:
                        pass
        
        disk_files = glob.glob("/var/lib/hci/aether/volumes/*/*.raw")
        orphaned_disks = []
        for disk_path in disk_files:
            normalized = disk_path.replace("\\", "/")
            if "default-image-container" in normalized:
                continue
            filename = os.path.basename(normalized)
            if filename.endswith(".raw"):
                base = filename[:-4]
                match = re.match(r"^(.*)_disk\d+$", base)
                vm_name = match.group(1) if match else base
            else:
                vm_name = filename
            if vm_name not in active_vms:
                orphaned_disks.append(disk_path)
                
        if orphaned_disks:
            results["orphaned_disks_check"] = {
                "status": "WARN",
                "output": f"Found orphaned virtual disk files without corresponding VMs: {', '.join(orphaned_disks)}.\nThese files should be cleaned up."
            }
        else:
            results["orphaned_disks_check"] = {
                "status": "PASS",
                "output": "No orphaned virtual disk files found. All virtual disks are associated with active virtual machines."
            }
    except Exception as e:
        results["orphaned_disks_check"] = {
            "status": "FAIL",
            "output": f"Error during orphaned disks check: {str(e)}"
        }

    return results

def check_hardware(category):
    results = {}
    
    # 1. Host CPU Load Check
    update_current_check(category, "cpu_load")
    try:
        nproc = os.cpu_count() or 1
        with open("/proc/loadavg", "r") as f:
            load = float(f.readline().split()[0])
        pct = (load / nproc) * 100
        status = "PASS"
        if pct > 95:
            status = "FAIL"
        elif pct > 85:
            status = "WARN"
        msg = f"CPU cores: {nproc}\n1-minute load average: {load:.2f} ({pct:.1f}% load average factor)"
    except Exception as e:
        status = "FAIL"
        msg = f"Failed to parse host CPU loadavg: {str(e)}"
    results["cpu_load"] = {
        "status": status,
        "output": msg
    }
    
    # 2. Host RAM usage check
    update_current_check(category, "ram_usage")
    try:
        mem_total = 0
        mem_avail = 0
        with open("/proc/meminfo", "r") as f:
            for line in f:
                if line.startswith("MemTotal:"):
                    mem_total = int(line.split()[1])
                elif line.startswith("MemAvailable:"):
                    mem_avail = int(line.split()[1])
        used = mem_total - mem_avail
        pct = (used / mem_total) * 100 if mem_total > 0 else 0
        
        status = "PASS"
        if pct > 95:
            status = "FAIL"
        elif pct > 85:
            status = "WARN"
            
        msg = f"Total RAM: {mem_total / 1024:.1f} MB\nUsed RAM: {used / 1024:.1f} MB ({pct:.1f}% used)\nAvailable RAM: {mem_avail / 1024:.1f} MB"
    except Exception as e:
        status = "FAIL"
        msg = f"Failed to check host memory: {str(e)}"
    results["ram_usage"] = {
        "status": status,
        "output": msg
    }
    
    # 3. Host root disk partition check
    update_current_check(category, "disk_space")
    rc, out, err = run_cmd("df -h /")
    if rc == 0:
        lines = out.splitlines()
        pct_val = 0
        if len(lines) >= 2:
            parts = lines[1].split()
            if len(parts) >= 5:
                pct_str = parts[4].replace("%", "")
                pct_val = int(pct_str)
        status = "PASS"
        if pct_val > 90:
            status = "FAIL"
        elif pct_val > 80:
            status = "WARN"
        msg = f"Root Partition Disk Info:\n{out}"
    else:
        status = "FAIL"
        msg = f"Failed to check root filesystem space: {err or out}"
    results["disk_space"] = {
        "status": status,
        "output": msg
    }
    
    # 4. NTP sync check
    update_current_check(category, "ntp_sync")
    rc_active, out_active, err_active = run_cmd("systemctl is-active chronyd")
    if out_active != "active":
        status = "FAIL"
        msg = f"chronyd time synchronization service is not active (status: {out_active})."
    else:
        rc, out, err = run_cmd("chronyc tracking")
        if rc != 0:
            status = "FAIL"
            msg = f"Failed to execute chronyc tracking: {err or out}"
        else:
            ref_id = ""
            offset = 0.0
            for line in out.splitlines():
                if "reference id" in line.lower():
                    ref_id = line.split(":")[-1].strip()
                elif "system time" in line.lower():
                    try:
                        parts = line.split(":")[-1].strip().split()
                        val = float(parts[0])
                        offset = abs(val)
                    except Exception:
                        pass
            
            if not ref_id or ref_id.startswith("0.0.0.0") or "unsynchronised" in ref_id.lower():
                status = "FAIL"
                msg = f"chronyd is active but time is UNSYNCHRONIZED (Reference ID: {ref_id or 'none'}).\n{out}"
            elif offset > 5.0:
                status = "FAIL"
                msg = f"chronyd is synchronized, but clock offset is critically high ({offset:.6f} seconds)!\n{out}"
            elif offset > 1.0:
                status = "WARN"
                msg = f"chronyd is synchronized, but clock offset is high ({offset:.6f} seconds).\n{out}"
            else:
                status = "PASS"
                msg = f"Time is synchronized with NTP. Clock offset is {offset:.6f} seconds.\n{out}"
                
    results["ntp_sync"] = {
        "status": status,
        "output": msg
    }
    
    # 5. Host Virtualization Capabilities Check
    update_current_check(category, "host_virtualization")
    rc_kvm, out_kvm, err_kvm = run_cmd("test -c /dev/kvm")
    if rc_kvm == 0:
        status = "PASS"
        msg = "KVM hardware virtualization is enabled (/dev/kvm exists). QEMU can run VMs with full hardware acceleration."
    else:
        rc_cpu, out_cpu, _ = run_cmd("egrep -c '(vmx|svm)' /proc/cpuinfo")
        cpu_support = False
        try:
            if rc_cpu == 0 and int(out_cpu.strip()) > 0:
                cpu_support = True
        except Exception:
            pass
        if cpu_support:
            status = "WARN"
            msg = "KVM virtualization is disabled (/dev/kvm not found), but CPU supports VT-x/AMD-V. Enable virtualization in BIOS or load kvm kernel modules."
        else:
            status = "FAIL"
            msg = "Host lacks full virtualization capabilities. CPU does not support VT-x/AMD-V, and /dev/kvm is missing. QEMU must use slow software emulation (TCG)."
    results["host_virtualization"] = {
        "status": status,
        "output": msg
    }
    
    # 6. Firmware Upgrades Check
    update_current_check(category, "firmware_upgrades")
    rc_fw, out_fw, err_fw = run_cmd("fwupdmgr get-upgrades")
    status = "PASS"
    msg = "No firmware upgrades available."
    if rc_fw == 2:
        status = "WARN"
        msg = f"Firmware upgrades are available!\nSystem Output:\n{out_fw or err_fw}"
    elif rc_fw == 0 and "upgrade" in out_fw.lower() and "no upgrades" not in out_fw.lower():
        status = "WARN"
        msg = f"Firmware upgrades are available!\nSystem Output:\n{out_fw or err_fw}"
    elif rc_fw != 0:
        if "daemon" in err_fw.lower() or "daemon" in out_fw.lower() or "connect" in err_fw.lower():
            status = "PASS"
            msg = f"fwupd daemon is not running or not supported on this host environment.\n{out_fw or err_fw}"
        else:
            status = "WARN"
            msg = f"fwupdmgr get-upgrades returned warning or failed (exit code {rc_fw}):\n{err_fw or out_fw}"
    results["firmware_upgrades"] = {
        "status": status,
        "output": msg
    }
    
    # 7. DNS/NTP synchronization check
    update_current_check(category, "dns_ntp_sync_check")
    try:
        import socket
        local_ip = "127.0.0.1"
        try:
            s = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
            s.connect(("8.8.8.8", 80))
            local_ip = s.getsockname()[0]
            s.close()
        except Exception:
            pass
            
        cql_dns_ntp = "SELECT key, value FROM hydra.cluster_settings;"
        rc_dns_ntp, out_dns_ntp, err_dns_ntp = run_cmd(f"podman exec -i systemd-hydra-db cqlsh {local_ip} -e \"{cql_dns_ntp}\"")
        
        db_dns = []
        db_ntp = []
        
        if rc_dns_ntp == 0:
            for line in out_dns_ntp.splitlines():
                if "dns_servers" in line:
                    parts = line.split("|")
                    if len(parts) >= 2:
                        db_dns = [d.strip() for d in parts[1].strip().split(",") if d.strip()]
                elif "ntp_servers" in line:
                    parts = line.split("|")
                    if len(parts) >= 2:
                        db_ntp = [n.strip() for n in parts[1].strip().split(",") if n.strip()]
        
        if rc_dns_ntp != 0 or not db_dns:
            status = "WARN"
            msg = f"Could not fetch DNS/NTP settings from ScyllaDB (table might not be initialized yet): {err_dns_ntp or out_dns_ntp}"
        else:
            local_dns = []
            if os.path.exists("/etc/resolv.conf"):
                with open("/etc/resolv.conf", "r") as f:
                    for line in f:
                        if line.strip().startswith("nameserver"):
                            parts = line.split()
                            if len(parts) >= 2:
                                local_dns.append(parts[1].strip())
                                
            local_ntp = []
            if os.path.exists("/etc/chrony.conf"):
                with open("/etc/chrony.conf", "r") as f:
                    for line in f:
                        if line.strip().startswith("server") or line.strip().startswith("pool"):
                            parts = line.split()
                            if len(parts) >= 2:
                                local_ntp.append(parts[1].strip())
                                
            dns_issues = [d for d in db_dns if d not in local_dns]
            ntp_issues = [n for n in db_ntp if n not in local_ntp]
            
            issues = []
            if dns_issues:
                issues.append(f"missing DNS server(s) in /etc/resolv.conf: {', '.join(dns_issues)}")
            if ntp_issues:
                issues.append(f"missing NTP server(s) in /etc/chrony.conf: {', '.join(ntp_issues)}")
                
            if issues:
                status = "FAIL"
                msg = f"DNS/NTP synchronization mismatch: " + " & ".join(issues) + f"\nDB Config: DNS={db_dns}, NTP={db_ntp}\nLocal Config: DNS={local_dns}, NTP={local_ntp}"
            else:
                status = "PASS"
                msg = f"DNS and NTP configurations are successfully synchronized with the cluster settings database.\nLocal Config: DNS={local_dns}, NTP={local_ntp}"
    except Exception as e:
        status = "FAIL"
        msg = f"Error running DNS/NTP synchronization check: {str(e)}"
        
    results["dns_ntp_sync_check"] = {
        "status": status,
        "output": msg
    }
    
    return results

def main():
    category = "all"
    if len(sys.argv) > 2 and sys.argv[1] == "--category":
        category = sys.argv[2]
        
    # Clear any old progress file
    try:
        if os.path.exists(f"/tmp/mimir_check_{category}"):
            os.remove(f"/tmp/mimir_check_{category}")
    except Exception:
        pass

    results = {}
    if category == "services" or category == "all":
        results.update(check_services(category))
    if category == "storage" or category == "all":
        results.update(check_storage(category))
    if category == "hardware" or category == "all":
        results.update(check_hardware(category))
        
    # Clean up progress file at the end
    try:
        if os.path.exists(f"/tmp/mimir_check_{category}"):
            os.remove(f"/tmp/mimir_check_{category}")
    except Exception:
        pass

    print(json.dumps(results, indent=2))

if __name__ == "__main__":
    main()
