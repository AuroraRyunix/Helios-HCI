        if active_vali_ip:
            vali_status = "PASS"
            vali_msg = f"Vali is active on node {active_vali_ip}. DRS Score: {balance_score}%"
        else:
            vali_status = "FAIL"
            vali_msg = "Vali placement manager leader port 9095 is unresponsive on all nodes in the cluster."
    except Exception as e:
        vali_status = "FAIL"
        vali_msg = f"Error checking Vali leader status: {str(e)}"
    results["vali_leader_status"] = {
        "status": vali_status,
        "output": vali_msg
    }

    # 14. ScyllaDB Tasks Schema
    update_current_check(category, "scylladb_tasks_schema")
    try:
        db_schema_status = "PASS"
        db_schema_msg = "ScyllaDB task schemas and node tables are queryable."
        
        import socket
        local_ip = "127.0.0.1"
        try:
            s = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
            s.connect(("8.8.8.8", 80))
            local_ip = s.getsockname()[0]
            s.close()
        except Exception:
            pass
            
        missing = []
        for table in ["vali_tasks", "nodes", "vali_drs_history"]:
            cql_check = f"SELECT * FROM hydra.{table} LIMIT 1;"
            rc, _, err = run_cmd(f"podman exec -i systemd-hydra-db cqlsh {local_ip} -e \"{cql_check}\"")
            if rc != 0:
                missing.append(table)
        
        if missing:
            db_schema_status = "FAIL"
            db_schema_msg = f"The following tables are missing or not queryable in ScyllaDB: {', '.join(missing)}"
    except Exception as e:
        db_schema_status = "FAIL"
        db_schema_msg = f"Error checking ScyllaDB schemas: {str(e)}"
    results["scylladb_tasks_schema"] = {
        "status": db_schema_status,
        "output": db_schema_msg
    }

    # 15. Security Configuration Audit
    update_current_check(category, "security_config_audit")
    try:
        sec_status = "PASS"
        sec_msg = "Security audit passed. Default credentials for user 'helios' have been changed."
        
        import socket
        local_ip = "127.0.0.1"
        try:
            s = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
            s.connect(("8.8.8.8", 80))
            local_ip = s.getsockname()[0]
            s.close()
        except Exception:
            pass
            
        cql_pw = "SELECT JSON password_hash FROM hydra.users WHERE username = 'helios';"
        rc, out, err = run_cmd(f"podman exec -i systemd-hydra-db cqlsh {local_ip} -e \"{cql_pw}\"")
        if rc == 0:
            pw_hash = None
            for line in out.splitlines():
                line = line.strip()
                if line.startswith("{") and line.endswith("}"):
                    try:
                      j = json.loads(line)
                      pw_hash = j.get("password_hash")
                    except:
                      pass
            if pw_hash:
                is_default = False
                try:
                    parts = pw_hash.split('$')
                    if len(parts) == 4:
                        algo, iterations, salt, hash_b64 = parts
                        if algo == "pbkdf2_sha256":
                            import hashlib, base64, secrets
                            iterations = int(iterations)
                            hash_bytes = hashlib.pbkdf2_hmac('sha256', b'helios', salt.encode('utf-8'), iterations)
                            expected_b64 = base64.b64encode(hash_bytes).decode('utf-8')
                            is_default = secrets.compare_digest(hash_b64, expected_b64)
                except Exception as e:
                    pass
                
                if is_default:
                    sec_status = "WARN"
                    sec_msg = "Security risk: Default administrator account 'helios' is still using the default password 'helios'. Please change it immediately."
            else:
                sec_status = "PASS"
                sec_msg = "Default administrator account 'helios' password hash not found or changed."
        else:
            rc_db, out_db, _ = run_cmd("systemctl is-active hydra-db")
            if rc_db == 0 and out_db.strip() == "active":
                sec_status = "FAIL"
                sec_msg = f"Failed to query users table for password audit: {err or out}"
            else:
                sec_status = "PASS"
                sec_msg = "ScyllaDB is inactive on this host (maintenance mode). Skipping credentials audit."
    except Exception as e:
        sec_status = "FAIL"
        sec_msg = f"Error performing security audit: {str(e)}"
    results["security_config_audit"] = {
        "status": sec_status,
        "output": sec_msg
    }
    
    # 22. Powered Off VMs check
    update_current_check(category, "virsh_power_off_check")
    try:
        rc, out, err = run_cmd("virsh list --all")
        if rc == 0:
            powered_off_vms = []
            for line in out.splitlines():
                if "shut off" in line or "powered off" in line:
                    parts = line.split()
                    if len(parts) >= 2:
                        powered_off_vms.append(parts[1])
            if powered_off_vms:
                results["virsh_power_off_check"] = {
                    "status": "WARN",
                    "output": f"Found powered-off virtual machines in virsh: {', '.join(powered_off_vms)}.\nPowered off VMs should not exist in virsh list (they should be undefined when powered off)."
                }
            else:
                results["virsh_power_off_check"] = {
                    "status": "PASS",
                    "output": "No powered-off virtual machines found in virsh. All configured VMs are in active state."
                }
        else:
            results["virsh_power_off_check"] = {
                "status": "FAIL",
                "output": f"Failed to query virsh VM list: {err or out}"
            }
    except Exception as e:
        results["virsh_power_off_check"] = {
            "status": "FAIL",
            "output": f"Error during virsh power off check: {str(e)}"
        }

    # 23. Stuck Catalyst Tasks check
    update_current_check(category, "stuck_tasks_check")
    try:
        local_ip = "127.0.0.1"
        try:
            s = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
            s.connect(("8.8.8.8", 80))
            local_ip = s.getsockname()[0]
            s.close()
        except Exception:
            pass
        
        cql = "SELECT JSON task_id, service, action, status, created_at FROM hydra.catalyst_tasks;"
        rc, out, err = run_cmd(f"podman exec -i systemd-hydra-db cqlsh {local_ip} -e \"{cql}\"")
        if rc == 0:
            stuck_tasks = []
            now_ms = int(time.time() * 1000)
            for line in out.splitlines():
                line = line.strip()
                if line.startswith("{") and line.endswith("}"):
                    try:
                        task = json.loads(line)
                        status = task.get("status")
                        created_at = task.get("created_at")
                        if status in ["pending", "processing"] and created_at:
                            if now_ms - int(created_at) > 10 * 60 * 1000:
                                stuck_tasks.append(f"{task.get('task_id')} ({task.get('service')} - {task.get('action')})")
                    except Exception:
                        pass
            if stuck_tasks:
                results["stuck_tasks_check"] = {
                    "status": "WARN",
                    "output": f"Found stuck Catalyst tasks: {', '.join(stuck_tasks)}.\nThese tasks have been pending or processing for more than 10 minutes."
                }
            else:
                results["stuck_tasks_check"] = {
                    "status": "PASS",
                    "output": "No stuck Catalyst tasks found. All pending or processing tasks are running within normal duration thresholds."
                }
        else:
            results["stuck_tasks_check"] = {
                "status": "FAIL",
                "output": f"Failed to query catalyst tasks: {err or out}"
            }
    except Exception as e:
        results["stuck_tasks_check"] = {
            "status": "FAIL",
            "output": f"Error during stuck tasks check: {str(e)}"
        }

    # 24. Urbosa Compliance check
    update_current_check(category, "urbosa_compliance")
    try:
        import socket
        import ipaddress
        compliance_issues = []
        
        # 1. Check IP forwarding status
        rc_fwd, out_fwd, _ = run_cmd("cat /proc/sys/net/ipv4/ip_forward")
        if rc_fwd != 0 or out_fwd.strip() != "1":
            compliance_issues.append("IPv4 forwarding is DISABLED (/proc/sys/net/ipv4/ip_forward is not 1)")
            
        # 2. Get local active interfaces and subnets
        rc_addr, out_addr, _ = run_cmd("ip -o addr show")
        local_subnets = []
        if rc_addr == 0:
            for line in out_addr.splitlines():
                parts = line.split()
                if "inet" in parts:
                    idx = parts.index("inet")
                    cidr = parts[idx+1]
                    local_subnets.append(cidr)

        # 3. Retrieve local hypervisor IP
        local_ip = "127.0.0.1"
        try:
            s = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
            s.connect(("8.8.8.8", 80))
            local_ip = s.getsockname()[0]
            s.close()
        except Exception:
            pass

        # 4. Get ScyllaDB configurations
        t0_routers = []
        cql_t0 = "SELECT JSON uplink_interface, uplink_ip FROM hydra.urbosa_t0_routers;"
        rc_t0, out_t0, _ = run_cmd(f"podman exec -i systemd-hydra-db cqlsh {local_ip} -e \"{cql_t0}\" || true")
        if rc_t0 == 0 and out_t0:
            for line in out_t0.splitlines():
                line = line.strip()
                if line.startswith("{") and line.endswith("}"):
                    try:
                        t0_routers.append(json.loads(line))
                    except:
                        pass

        segments = []
        cql_seg = "SELECT JSON subnet_cidr, name FROM hydra.urbosa_segments;"
        rc_seg, out_seg, _ = run_cmd(f"podman exec -i systemd-hydra-db cqlsh {local_ip} -e \"{cql_seg}\" || true")
        if rc_seg == 0 and out_seg:
            for line in out_seg.splitlines():
                line = line.strip()
                if line.startswith("{") and line.endswith("}"):
                    try:
                        segments.append(json.loads(line))
                    except:
                        pass

        # 5. Check physical interfaces
        rc_link, out_link, _ = run_cmd("ip -o link show")
        active_links = []
        if rc_link == 0:
            for line in out_link.splitlines():
                parts = line.split(":")
                if len(parts) > 1:
                    link_name = parts[1].strip().split("@")[0].strip()
                    active_links.append(link_name)

        for t0 in t0_routers:
            iface = t0.get("uplink_interface")
            if iface and iface not in active_links:
                # Fallback to fetch default route interface when the configured interface is not detected
                fallback_if = None
                rc_rt, out_rt, _ = run_cmd("ip route get 8.8.8.8")
                if rc_rt == 0 and "dev " in out_rt:
                    parts = out_rt.split()
                    if "dev" in parts:
                        idx = parts.index("dev")
                        if idx + 1 < len(parts):
                            fallback_if = parts[idx+1]
                if not fallback_if:
                    rc_rt2, out_rt2, _ = run_cmd("ip route show")
                    if rc_rt2 == 0 and out_rt2:
                        for r_line in out_rt2.splitlines():
                            if "default" in r_line:
                                r_parts = r_line.split()
                                if "dev" in r_parts:
                                    r_idx = r_parts.index("dev")
                                    if r_idx + 1 < len(r_parts):
                                        fallback_if = r_parts[r_idx+1]
                                        break
                if fallback_if and fallback_if in active_links:
                    # Fallback interface detected and active, do not report compliance issue
                    pass
                else:
                    compliance_issues.append(f"Configured Tier-0 uplink interface '{iface}' does NOT exist or is not active on this host.")

        # 6. Check for subnet overlap conflicts
        for seg in segments:
            seg_cidr = seg.get("subnet_cidr")
            seg_name = seg.get("name")
            if seg_cidr:
                try:
                    seg_net = ipaddress.ip_network(seg_cidr, strict=False)
                    for local_cidr in local_subnets:
                        local_net = ipaddress.ip_network(local_cidr, strict=False)
                        if local_net.network_address == seg_net.network_address:
                            continue
                        if seg_net.overlaps(local_net):
                            compliance_issues.append(
                                f"Overlay segment '{seg_name}' ({seg_cidr}) overlaps with host/underlay network ({local_cidr})."
                            )
                except Exception as ex:
                    compliance_issues.append(f"Invalid segment CIDR '{seg_cidr}' configuration: {str(ex)}")

        if compliance_issues:
            status = "FAIL"
            msg = "Urbosa networking compliance checks FAILED:\n- " + "\n- ".join(compliance_issues)
        else:
            status = "PASS"
            msg = "Urbosa network compliance checks passed. Host routing configurations, physical interfaces, and segment subnets are fully compatible."

    except Exception as e:
        status = "FAIL"
        msg = f"Error running Urbosa compliance check: {str(e)}"

    # 36. SSH Known Hosts Seeding Check
    update_current_check(category, "ssh_known_hosts_seeding")
    try:
        hosts = []
        if os.path.exists("/etc/hci/cluster.json"):
            with open("/etc/hci/cluster.json", "r") as f:
                hosts = json.load(f).get("hosts", [])
        
        failed_hosts = []
        passed_hosts = []
        for h in hosts:
            node_ip = h.get("ip")
            node_hostname = h.get("hostname")
            if not node_ip:
                continue
            # Run ssh connection check by IP address
            res = subprocess.run(
                f"ssh -o BatchMode=yes -o ConnectTimeout=2 -o StrictHostKeyChecking=yes {node_ip} exit",
                shell=True,
                stdout=subprocess.PIPE,
                stderr=subprocess.PIPE
            )
            
            if res.returncode != 0:
                err_msg = res.stderr.decode('utf-8', errors='ignore').strip() or f"exit code {res.returncode}"
                failed_hosts.append(f"{node_hostname} ({node_ip}) failed: {err_msg}")
            else:
                passed_hosts.append(f"{node_hostname} ({node_ip})")

        if failed_hosts:
            status = "FAIL"
            msg = "SSH inter-node trust verification FAILED:\n- " + "\n- ".join(failed_hosts)
        else:
            status = "PASS"
            msg = f"SSH inter-node trust fully verified for: {', '.join(passed_hosts)}."
    except Exception as ex:
        status = "FAIL"
        msg = f"Error executing SSH trust verification check: {str(ex)}"
    
    results["ssh_known_hosts_seeding"] = {
        "status": status,
        "output": msg
    }

    return results

def check_storage(category):
    results = {}
    
    controller_ip = "127.0.0.1"
    try:
        import json
        if os.path.exists("/etc/hci/cluster.json"):
            with open("/etc/hci/cluster.json", "r") as f:
                cdata = json.load(f)
                hosts = cdata.get("hosts", [])
                if hosts:
                    controller_ip = ",".join([h["ip"] for h in hosts])
    except Exception:
        pass
        
    # 1. Aether peer status (Aether Nodes)
    update_current_check(category, "aether_peers")
    rc, out, err = run_cmd(f"podman exec -e LS_CONTROLLERS={controller_ip} systemd-aether linstor node list")
    if rc == 0:
        offline = "OFFLINE" in out.upper() or "ERROR" in out.upper()
        status = "FAIL" if offline else "PASS"
        msg = out
    else:
        status = "FAIL"
        msg = f"Failed to query Aether node list: {err or out}"
    results["aether_peers"] = {
        "status": status,
        "output": msg
    }
    
    # 2. Aether volume status (Aether Resources)
    update_current_check(category, "aether_volume")
    rc, out, err = run_cmd(f"podman exec -e LS_CONTROLLERS={controller_ip} systemd-aether linstor resource list")
    if rc == 0:
        failed = "ERROR" in out.upper() or "FATAL" in out.upper() or "DEVIATING" in out.upper()
        db_in_use = False
        for line in out.splitlines():
            if "linstor-db" in line and "InUse" in line:
                db_in_use = True
        if failed:
            status = "FAIL"
            msg = out
        elif not db_in_use:
            status = "FAIL"
            msg = f"CRITICAL: The database volume (linstor-db) is NOT active (InUse) on any node.\n\nLinstor Resource List:\n{out}"
        else:
            status = "PASS"
            msg = out
    else:
        status = "FAIL"
        msg = f"Failed to query Aether resource list: {err or out}"
    results["aether_volume"] = {
        "status": status,
        "output": msg
    }
    
    # 3. Disk storage pool mount check (Aether Storage Pools)
    update_current_check(category, "aether_storage_pools")
    rc, out, err = run_cmd(f"podman exec -e LS_CONTROLLERS={controller_ip} systemd-aether linstor storage-pool list")
    if rc == 0:
        ok = "default-pool" in out and "Ok" in out
        status = "PASS" if ok else "FAIL"
        msg = out
    else:
        status = "FAIL"
        msg = f"Failed to query Aether storage pool: {err or out}"
    results["aether_storage_pools"] = {
        "status": status,
        "output": msg
    }

    # 4. Storage volume capacity check
    update_current_check(category, "storage_capacity")
    volumes_cap = [
        ("default-vm-container", "/var/lib/hci/aether/volumes/default-vm-container"),
        ("default-image-container", "/var/lib/hci/aether/volumes/default-image-container")
    ]
    statuses_cap = []
    messages_cap = []
    for name, vol_path in volumes_cap:
        if os.path.exists(vol_path):
            try:
                stat = os.statvfs(vol_path)
                total = stat.f_blocks * stat.f_frsize
                free = stat.f_bavail * stat.f_frsize
                used = total - free
                pct = (used / total) * 100 if total > 0 else 0
                
                vol_status = "PASS"
                if pct > 90.0:
                    vol_status = "FAIL"
                elif pct > 80.0:
                    vol_status = "WARN"
                
                statuses_cap.append(vol_status)
                messages_cap.append(f"Volume: {name}\nPath: {vol_path}\nTotal Space: {total // 1024**3} GB\nUsed Space: {used // 1024**3} GB ({pct:.1f}% used)\nFree Space: {free // 1024**3} GB")
            except Exception as e:
                statuses_cap.append("FAIL")
                messages_cap.append(f"{name}: Failed to check storage path statistics: {str(e)}")
        else:
            statuses_cap.append("PASS")
            messages_cap.append(f"{name}: standby / not mounted locally on this host (Aether).")
                
    status = "FAIL" if "FAIL" in statuses_cap else ("WARN" if "WARN" in statuses_cap else "PASS")
    msg = "\n\n".join(messages_cap)
    results["storage_capacity"] = {
        "status": status,
        "output": msg
    }
    
    # 5. Aether Split Brain Check
    update_current_check(category, "aether_split_brain")
    rc, out, err = run_cmd(f"podman exec -e LS_CONTROLLERS={controller_ip} systemd-aether linstor resource list")
    if rc == 0:
        sb = "SplitBrain" in out or "Inconsistent" in out
        status = "FAIL" if sb else "PASS"
        msg = "No Aether split-brain detected." if not sb else f"WARNING: Aether Split-brain detected!\n{out}"
    else:
        status = "FAIL"
        msg = f"Failed to query Aether status: {err or out}"
    results["aether_split_brain"] = {
        "status": status,
        "output": msg
    }
    
    # 6. Aether Heal Pending Check
    update_current_check(category, "aether_heal_pending")
    rc, out, err = run_cmd(f"podman exec -e LS_CONTROLLERS={controller_ip} systemd-aether linstor volume list")
    if rc == 0:
        syncing = "Syncing" in out or "PausedSync" in out
        status = "WARN" if syncing else "PASS"
        msg = "No Aether volume synchronization active (healthy)." if not syncing else f"Aether volume(s) are syncing:\n{out}"
    else:
        status = "FAIL"
        msg = f"Failed to query Aether volume status: {err or out}"
    results["aether_heal_pending"] = {
        "status": status,
        "output": msg
    }
    
    # 7. Storage Pool Space Utilization Check
    update_current_check(category, "aether_storage_pools_space")
    rc, out, err = run_cmd(f"podman exec -e LS_CONTROLLERS={controller_ip} systemd-aether linstor storage-pool list")
    if rc == 0:
        status = "PASS"
        if "Ok" not in out:
            status = "WARN"
        msg = f"Aether storage pool status:\n{out}"
    else:
        status = "FAIL"
        msg = f"Failed to check Aether storage pool status: {err or out}"
    results["aether_storage_pools_space"] = {
        "status": status,
        "output": msg
    }
    
    # 8. Storage Mount Options Check
    update_current_check(category, "storage_mount_options")
    volumes = [
        ("default-vm-container", "/var/lib/hci/aether/volumes/default-vm-container"),
        ("default-image-container", "/var/lib/hci/aether/volumes/default-image-container")
    ]
    
    statuses = []
    messages = []
    
    for name, vol_path in volumes:
        role = get_drbd_role(name)
        should_be_mounted = (role == "Primary")
            
        rc_m, out_m, err_m = run_cmd(f"findmnt -o OPTIONS -n {vol_path}")
        if rc_m != 0:
            if not should_be_mounted:
                statuses.append("PASS")
                messages.append(f"{name}: standby / not mounted locally (Secondary).")
            else:
                statuses.append("FAIL")
                messages.append(f"{name}: CRITICAL: Primary volume is NOT mounted locally!")
        else:
            if not should_be_mounted:
                statuses.append("WARN")
                messages.append(f"{name}: WARNING: Secondary volume is mounted locally!")
            else:
                options = [opt.strip() for opt in out_m.split(",")]
                if "ro" in options:
                    statuses.append("FAIL")
                    messages.append(f"{name}: CRITICAL: mounted READ-ONLY! Active options: {out_m}")
                else:
                    statuses.append("PASS")
                    messages.append(f"{name}: mounted read-write (rw). Options: {out_m}")
                
    status = "FAIL" if "FAIL" in statuses else ("WARN" if "WARN" in statuses else "PASS")
    msg = "\n".join(messages)
    
    results["storage_mount_options"] = {
        "status": status,
        "output": msg
    }
    
    # 9. Storage Volume Writable Check
    update_current_check(category, "storage_volume_writable")
    statuses = []
    messages = []
    
    for name, vol_path in volumes:
        test_file = os.path.join(vol_path, ".mimir_rw_check")
        role = get_drbd_role(name)
        should_be_mounted = (role == "Primary")
            
        rc_m, _, _ = run_cmd(f"findmnt {vol_path}")
        if rc_m != 0:
            if not should_be_mounted:
                statuses.append("PASS")
                messages.append(f"{name}: standby / not mounted locally.")
            else:
                statuses.append("FAIL")
                messages.append(f"{name}: CRITICAL: Primary volume is not mounted, cannot write.")
        else:
            try:
                import uuid
                test_content = f"mimir-test-{uuid.uuid4()}"
                with open(test_file, "w") as f:
                    f.write(test_content)
                    f.flush()
                    os.fsync(f.fileno())
                
                with open(test_file, "r") as f:
                    read_back = f.read().strip()
                    
                if read_back != test_content:
                    statuses.append("FAIL")
                    messages.append(f"{name}: CRITICAL: read back content mismatch!")
                else:
                    statuses.append("PASS")
                    messages.append(f"{name}: Successfully verified read-write operations.")
                
                os.remove(test_file)
            except Exception as e:
                statuses.append("FAIL")
                messages.append(f"{name}: Failed to perform write-read check: {str(e)}")
                if os.path.exists(test_file):
                    try:
                        os.remove(test_file)
                    except Exception:
                        pass
                        
    status = "FAIL" if "FAIL" in statuses else "PASS"
    msg = "\n".join(messages)
    
    results["storage_volume_writable"] = {
        "status": status,
        "output": msg
    }
    
    # 10. /etc/fstab safety check
    update_current_check(category, "fstab_safety_check")
    status = "PASS"
    msg = "No storage mount entries found in /etc/fstab."
    
    try:
        with open("/etc/fstab", "r") as f:
            lines = f.readlines()
            
        brick_entries = []
        for line in lines:
            line = line.strip()
            if not line or line.startswith("#"):
                continue
            parts = line.split()
            if len(parts) >= 4 and "/var/lib/hci/aether/bricks/" in parts[1]:
                brick_entries.append((parts[0], parts[1], parts[3]))
                
        if brick_entries:
            failed_safety = []
            for spec, mnt, opts in brick_entries:
                opt_list = opts.split(",")
                has_uuid = spec.startswith("UUID=")
                has_nofail = "nofail" in opt_list
                has_timeout = "x-systemd.device-timeout=5s" in opt_list or any("x-systemd.device-timeout" in o for o in opt_list)
                
                issues = []
                if not has_uuid:
                    issues.append("uses raw device path instead of UUID")
                if not has_nofail:
                    issues.append("missing 'nofail' flag")
                if not has_timeout:
                    issues.append("missing 'x-systemd.device-timeout=5s' flag")
                    
                if issues:
                    failed_safety.append(f"Mount {mnt} ({spec}): " + ", ".join(issues))
                    
            if failed_safety:
                status = "FAIL"
                msg = "The following fstab storage mounts do not meet safety requirements:\n" + "\n".join(failed_safety)
            else:
                status = "PASS"
                msg = f"All {len(brick_entries)} fstab storage mount(s) use UUIDs and contain safe timeout/recovery flags."
    except Exception as e:
        status = "FAIL"
        msg = f"Failed to read or parse /etc/fstab: {str(e)}"
        
    results["fstab_safety_check"] = {
        "status": status,
        "output": msg
    }
        
    # 11. Orphaned Disks check
    update_current_check(category, "orphaned_disks_check")
    try:
        import glob
        local_ip = "127.0.0.1"
        try:
            with open("/etc/hci/spectrum/spectrum.env", "r") as f:
                for line in f:
                    if "=" in line:
                        k, v = line.strip().split("=", 1)
                        if k == "LOCAL_HYPERVISOR_IP":
                            local_ip = v.strip()
        except Exception:
            pass
            
        if local_ip == "127.0.0.1":
            try:
                s = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
                s.connect(("8.8.8.8", 80))
                local_ip = s.getsockname()[0]
                s.close()
            except Exception:
                pass
        
        cql = "SELECT JSON name, disks_list FROM hydra.vms;"
        rc, out, err = run_cmd(f"podman exec -i systemd-hydra-db cqlsh {local_ip} -e \"{cql}\"")
        registered_disk_paths = set()
        if rc == 0:
            for line in out.splitlines():
                line = line.strip()
                if line.startswith("{") and line.endswith("}"):
                    try:
                        vm = json.loads(line)
                        vm_name = vm.get("name")
                        disks_str = vm.get("disks_list", "")
                        if vm_name:
                            if not disks_str or disks_str == "NONE":
                                primary_path = f"/var/lib/hci/aether/volumes/default-vm-container/{vm_name}.raw"
                                registered_disk_paths.add(primary_path)
                            else:
                                for idx, entry in enumerate(disks_str.split(",")):
                                    parts = entry.split(":")
                                    container = parts[1] if len(parts) > 1 else "default-vm-container"
                                    if idx == 0:
                                        d_path = f"/var/lib/hci/aether/volumes/{container}/{vm_name}.raw"
                                    else:
                                        d_path = f"/var/lib/hci/aether/volumes/{container}/{vm_name}_disk{idx}.raw"
                                    registered_disk_paths.add(d_path)
                    except Exception:
                        pass
        
        disk_files = glob.glob("/var/lib/hci/aether/volumes/*/*.raw")
        orphaned_disks = []
        for disk_path in disk_files:
            normalized = disk_path.replace("\\", "/").strip()
            if "default-image-container" in normalized:
                continue
            if normalized not in registered_disk_paths:
                orphaned_disks.append(disk_path)
                
        if orphaned_disks:
            results["orphaned_disks_check"] = {
                "status": "WARN",
                "output": f"Found orphaned virtual disk files without corresponding VMs: {', '.join(orphaned_disks)}.\nThese files should be cleaned up."
            }
        else:
            results["orphaned_disks_check"] = {
                "status": "PASS",
                "output": "No orphaned virtual disk files found. All virtual disks are associated with active virtual machines."
            }
    except Exception as e:
        results["orphaned_disks_check"] = {
            "status": "FAIL",
            "output": f"Error during orphaned disks check: {str(e)}"
        }

    # 12. Broken Disks check
    update_current_check(category, "broken_disks_check")
    try:
        broken_replicas = []
        controller_ips = "127.0.0.1"
        try:
            if os.path.exists("/etc/hci/cluster.json"):
                with open("/etc/hci/cluster.json", "r") as f:
                    cdata = json.load(f)
                    hosts = cdata.get("hosts", [])
                    if hosts:
                        controller_ips = ",".join([h["ip"] for h in hosts])
        except Exception:
            pass

        # 1. Query Linstor volume list
        rc_v, out_v, err_v = run_cmd(f"podman exec -e LS_CONTROLLERS={controller_ips} systemd-aether linstor --no-color volume list")
        if rc_v == 0:
            import re
            ansi_escape = re.compile(r'\\x1B(?:[@-Z\\-_]|\\[[0-?]*[ -/]*[@-~])')
            for line in out_v.splitlines():
                line = line.strip()
                if line.startswith("|") and not ("Resource" in line or "=====" in line or "MinorNr" in line):
                    parts = [p.strip() for p in line.split("|")]
                    if len(parts) >= 11:
                        resource = ansi_escape.sub('', parts[1]).strip()
                        node = ansi_escape.sub('', parts[2]).strip()
                        pool = ansi_escape.sub('', parts[3]).strip()
                        state = ansi_escape.sub('', parts[9]).strip()
                        
                        # Apply healthy rules
                        is_diskless_pool = "diskless" in pool.lower()
                        if is_diskless_pool:
                            is_healthy = state in ["Diskless", "TieBreaker"]
                        else:
                            is_healthy = state == "UpToDate"
                        
                        if not is_healthy:
                            broken_replicas.append(f"Replica of resource '{resource}' on node '{node}' (pool '{pool}') is in state '{state}'")
        else:
            broken_replicas.append(f"Failed to query Linstor volume list: {err_v or out_v}")

        # 2. Check for lingering temporary uploads in local cache
        lingering_files = []
        import time
        now = time.time()
        temp_dirs = [
            "/var/lib/hci/aether/volumes/default-image-container/.tmp_uploads",
            "/var/lib/hci/aether/volumes/default-vm-container/.tmp_uploads"
        ]
        for tdir in temp_dirs:
            if os.path.exists(tdir):
                try:
                    for entry in os.scandir(tdir):
                        if entry.is_file():
                            mtime = entry.stat().st_mtime
                            age_seconds = now - mtime
                            if age_seconds > 7200: # 2 hours
                                size_mb = entry.stat().st_size / (1024 * 1024)
                                lingering_files.append(f"{entry.name} in {os.path.basename(tdir)} (size: {size_mb:.2f} MB, age: {age_seconds/3600:.1f} hours)")
                except Exception as ex:
                    pass

        # Determine health status based on findings
        if broken_replicas:
            results["broken_disks_check"] = {
                "status": "FAIL",
                "output": "CRITICAL: Broken or degraded disk replicas detected in Linstor:\n- " + "\n- ".join(broken_replicas)
            }
        elif lingering_files:
            results["broken_disks_check"] = {
                "status": "WARN",
                "output": "WARNING: Stale temporary upload files found in local cache (.tmp_uploads):\n- " + "\n- ".join(lingering_files) + "\nThese files are taking up local storage space and can be cleaned up."
            }
        else:
            results["broken_disks_check"] = {
                "status": "PASS",
                "output": "All Linstor disk replicas are healthy, and no stale temporary uploads were found in local cache."
            }
    except Exception as e:
        results["broken_disks_check"] = {
            "status": "FAIL",
            "output": f"Error during broken disks check: {str(e)}"
        }

    return results

def check_hardware(category):
    results = {}
    
    # 1. Host CPU Load Check
    update_current_check(category, "cpu_load")
    try:
        nproc = os.cpu_count() or 1
        with open("/proc/loadavg", "r") as f:
            load = float(f.readline().split()[0])
        pct = (load / nproc) * 100
        status = "PASS"
        if pct > 95:
            status = "FAIL"
        elif pct > 85:
            status = "WARN"
        msg = f"CPU cores: {nproc}\n1-minute load average: {load:.2f} ({pct:.1f}% load average factor)"
    except Exception as e:
        status = "FAIL"
        msg = f"Failed to parse host CPU loadavg: {str(e)}"
    results["cpu_load"] = {
        "status": status,
        "output": msg
    }
    
    # 2. Host RAM usage check
    update_current_check(category, "ram_usage")
    try:
        mem_total = 0
        mem_avail = 0
        with open("/proc/meminfo", "r") as f:
            for line in f:
                if line.startswith("MemTotal:"):
                    mem_total = int(line.split()[1])
                elif line.startswith("MemAvailable:"):
                    mem_avail = int(line.split()[1])
        used = mem_total - mem_avail
        pct = (used / mem_total) * 100 if mem_total > 0 else 0
        
        status = "PASS"
        if pct > 95:
            status = "FAIL"
        elif pct > 85:
            status = "WARN"
            
        msg = f"Total RAM: {mem_total / 1024:.1f} MB\nUsed RAM: {used / 1024:.1f} MB ({pct:.1f}% used)\nAvailable RAM: {mem_avail / 1024:.1f} MB"
    except Exception as e:
        status = "FAIL"
        msg = f"Failed to check host memory: {str(e)}"
    results["ram_usage"] = {
        "status": status,
        "output": msg
    }
    
    # 3. Host root disk partition check
    update_current_check(category, "disk_space")
    rc, out, err = run_cmd("df -h /")
    if rc == 0:
        lines = out.splitlines()
        pct_val = 0
        if len(lines) >= 2:
            parts = lines[1].split()
            if len(parts) >= 5:
                pct_str = parts[4].replace("%", "")
                pct_val = int(pct_str)
        status = "PASS"
        if pct_val > 90:
            status = "FAIL"
        elif pct_val > 80:
            status = "WARN"
        msg = f"Root Partition Disk Info:\n{out}"
    else:
        status = "FAIL"
        msg = f"Failed to check root filesystem space: {err or out}"
    results["disk_space"] = {
        "status": status,
        "output": msg
    }
    
    # 4. NTP sync check
    update_current_check(category, "ntp_sync")
    rc_active, out_active, err_active = run_cmd("systemctl is-active chronyd")
    if out_active != "active":
        status = "FAIL"
        msg = f"chronyd time synchronization service is not active (status: {out_active})."
    else:
        rc, out, err = run_cmd("chronyc tracking")
        if rc != 0:
            status = "FAIL"
            msg = f"Failed to execute chronyc tracking: {err or out}"
        else:
            ref_id = ""
            offset = 0.0
            for line in out.splitlines():
                if "reference id" in line.lower():
                    ref_id = line.split(":")[-1].strip()
                elif "system time" in line.lower():
                    try:
                        parts = line.split(":")[-1].strip().split()
                        val = float(parts[0])
                        offset = abs(val)
                    except Exception:
                        pass
            
            if not ref_id or ref_id.startswith("0.0.0.0") or "unsynchronised" in ref_id.lower():
                status = "FAIL"
                msg = f"chronyd is active but time is UNSYNCHRONIZED (Reference ID: {ref_id or 'none'}).\n{out}"
            elif offset > 5.0:
                status = "FAIL"
                msg = f"chronyd is synchronized, but clock offset is critically high ({offset:.6f} seconds)!\n{out}"
            elif offset > 1.0:
                status = "WARN"
                msg = f"chronyd is synchronized, but clock offset is high ({offset:.6f} seconds).\n{out}"
            else:
                status = "PASS"
                msg = f"Time is synchronized with NTP. Clock offset is {offset:.6f} seconds.\n{out}"
                
    results["ntp_sync"] = {
        "status": status,
        "output": msg
    }
    
    # 5. Host Virtualization Capabilities Check
    update_current_check(category, "host_virtualization")
    rc_kvm, out_kvm, err_kvm = run_cmd("test -c /dev/kvm")
    if rc_kvm == 0:
        status = "PASS"
        msg = "KVM hardware virtualization is enabled (/dev/kvm exists). QEMU can run VMs with full hardware acceleration."
    else:
        rc_cpu, out_cpu, _ = run_cmd("egrep -c '(vmx|svm)' /proc/cpuinfo")
        cpu_support = False
        try:
            if rc_cpu == 0 and int(out_cpu.strip()) > 0:
                cpu_support = True
        except Exception:
            pass
        if cpu_support:
            status = "WARN"
            msg = "KVM virtualization is disabled (/dev/kvm not found), but CPU supports VT-x/AMD-V. Enable virtualization in BIOS or load kvm kernel modules."
        else:
            status = "WARN"
            msg = "Host lacks full virtualization capabilities. CPU does not support VT-x/AMD-V, and /dev/kvm is missing. QEMU must use slow software emulation (TCG)."
    results["host_virtualization"] = {
        "status": status,
        "output": msg
    }
    
    # 6. Firmware Upgrades Check
    update_current_check(category, "firmware_upgrades")
    rc_fw, out_fw, err_fw = run_cmd("fwupdmgr get-upgrades")
    status = "PASS"
    msg = "No firmware upgrades available."
    if rc_fw == 2:
        status = "WARN"
        msg = f"Firmware upgrades are available!\nSystem Output:\n{out_fw or err_fw}"
    elif rc_fw == 0 and "upgrade" in out_fw.lower() and "no upgrades" not in out_fw.lower():
        status = "WARN"
        msg = f"Firmware upgrades are available!\nSystem Output:\n{out_fw or err_fw}"
    elif rc_fw != 0:
        if "daemon" in err_fw.lower() or "daemon" in out_fw.lower() or "connect" in err_fw.lower():
            status = "PASS"
            msg = f"fwupd daemon is not running or not supported on this host environment.\n{out_fw or err_fw}"
        else:
            status = "WARN"
            msg = f"fwupdmgr get-upgrades returned warning or failed (exit code {rc_fw}):\n{err_fw or out_fw}"
    results["firmware_upgrades"] = {
        "status": status,
        "output": msg
    }
    
    # 7. DNS/NTP synchronization check
    update_current_check(category, "dns_ntp_sync_check")
    try:
        import socket
        local_ip = "127.0.0.1"
        try:
            s = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
            s.connect(("8.8.8.8", 80))
            local_ip = s.getsockname()[0]
            s.close()
        except Exception:
            pass
            
        cql_dns_ntp = "SELECT key, value FROM hydra.cluster_settings;"
        rc_dns_ntp, out_dns_ntp, err_dns_ntp = run_cmd(f"podman exec -i systemd-hydra-db cqlsh {local_ip} -e \"{cql_dns_ntp}\"")
        
        db_dns = []
        db_ntp = []
        
        if rc_dns_ntp == 0:
            for line in out_dns_ntp.splitlines():
                if "dns_servers" in line:
                    parts = line.split("|")
                    if len(parts) >= 2:
                        db_dns = [d.strip() for d in parts[1].strip().split(",") if d.strip()]
                elif "ntp_servers" in line:
                    parts = line.split("|")
                    if len(parts) >= 2:
                        db_ntp = [n.strip() for n in parts[1].strip().split(",") if n.strip()]
        
        if rc_dns_ntp != 0 or not db_dns:
            status = "WARN"
            msg = f"Could not fetch DNS/NTP settings from ScyllaDB (table might not be initialized yet): {err_dns_ntp or out_dns_ntp}"
        else:
            local_dns = []
            if os.path.exists("/etc/resolv.conf"):
                with open("/etc/resolv.conf", "r") as f:
                    for line in f:
                        if line.strip().startswith("nameserver"):
                            parts = line.split()
                            if len(parts) >= 2:
                                local_dns.append(parts[1].strip())
                                
            local_ntp = []
            if os.path.exists("/etc/chrony.conf"):
                with open("/etc/chrony.conf", "r") as f:
                    for line in f:
                        if line.strip().startswith("server") or line.strip().startswith("pool"):
                            parts = line.split()
                            if len(parts) >= 2:
                                local_ntp.append(parts[1].strip())
                                
            dns_issues = [d for d in db_dns if d not in local_dns]
            ntp_issues = [n for n in db_ntp if n not in local_ntp]
            
            issues = []
            if dns_issues:
                issues.append(f"missing DNS server(s) in /etc/resolv.conf: {', '.join(dns_issues)}")
            if ntp_issues:
                issues.append(f"missing NTP server(s) in /etc/chrony.conf: {', '.join(ntp_issues)}")
                
            if issues:
                status = "WARN"
                msg = f"DNS/NTP synchronization mismatch: " + " & ".join(issues) + f"\nDB Config: DNS={db_dns}, NTP={db_ntp}\nLocal Config: DNS={local_dns}, NTP={local_ntp}"
            else:
                status = "PASS"
                msg = f"DNS and NTP configurations are successfully synchronized with the cluster settings database.\nLocal Config: DNS={local_dns}, NTP={local_ntp}"
    except Exception as e:
        status = "WARN"
        msg = f"Error running DNS/NTP synchronization check: {str(e)}"
        
    results["dns_ntp_sync_check"] = {
        "status": status,
        "output": msg
    }
    
    return results

def main():
    category = "all"
    if len(sys.argv) > 2 and sys.argv[1] == "--category":
        category = sys.argv[2]
        
    # Clear any old progress file
    try:
        if os.path.exists(f"/tmp/mimir_check_{category}"):
            os.remove(f"/tmp/mimir_check_{category}")
    except Exception:
        pass

    results = {}
    if category == "services" or category == "all":
        results.update(check_services(category))
    if category == "storage" or category == "all":
        results.update(check_storage(category))
    if category == "hardware" or category == "all":
        results.update(check_hardware(category))
        
    # Clean up progress file at the end
    try:
        if os.path.exists(f"/tmp/mimir_check_{category}"):
            os.remove(f"/tmp/mimir_check_{category}")
    except Exception:
        pass

    print(json.dumps(results, indent=2))

if __name__ == "__main__":
    main()
